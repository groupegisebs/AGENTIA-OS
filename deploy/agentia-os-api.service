[Unit]
Description=Agentic Factory — API
After=network.target postgresql.service
Wants=postgresql.service

[Service]
Type=exec
WorkingDirectory=/opt/apps/agentia-os/api
ExecStart=/usr/bin/dotnet /opt/apps/agentia-os/api/AgenticFactory.Api.dll
Restart=on-failure
RestartSec=30
KillSignal=SIGINT
SyslogIdentifier=agentia-os-api
User=ubuntu
Group=ubuntu

EnvironmentFile=/opt/apps/agentia-os/.env.api

TimeoutStopSec=30

[Install]
WantedBy=multi-user.target
