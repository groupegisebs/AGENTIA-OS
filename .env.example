# Clé API OpenAI (ou compatible) — laisser vide pour le mode mock hors-ligne
OPENAI_API_KEY=

# URL de base de l'API (optionnel, défaut: https://api.openai.com/v1)
OPENAI_BASE_URL=https://api.openai.com/v1

# Modèle à utiliser
OPENAI_MODEL=gpt-4o-mini

# Hôte et port du serveur
HOST=0.0.0.0
PORT=8000

# --- Facturation SaaS (devise : EUR) ---
# Organisation par défaut du MVP (mono-tenant)
DEFAULT_ORGANIZATION_ID=org-demo-0001
DEFAULT_ORGANIZATION_NAME=Organisation démo

# Frais de base par déploiement (0 = utiliser le tarif du plan d'abonnement)
DEPLOYMENT_BASE_FEE=0

# Multiplicateur de complexité par composant au-delà de 3 (ex. 0.15 = +15 % par composant)
DEPLOYMENT_COMPLEXITY_MULTIPLIER=0.15

# Devise de facturation (EUR — tarification documentée en euros)
BILLING_CURRENCY=EUR

# --- GiseBsPayGateway (laisser vide → mock) ---
# URL publique du service (ex. https://gisebsapipaygateway.gisebs.com)
GISEBS_PAY_GATEWAY_URL=
GISEBS_PAY_APP_CODE=AGENTIAOS
GISEBS_PAY_API_KEY=

# URLs de retour après checkout Stripe
GISEBS_PAY_SUCCESS_URL=http://localhost:8000/paiement/succes
GISEBS_PAY_CANCEL_URL=http://localhost:8000/paiement/annule

# Codes produit/plan dans le catalogue GiseBsPayGateway
GISEBS_PAY_DEPLOYMENT_PRODUCT_CODE=AGENT-DEPLOY
GISEBS_PAY_DEPLOYMENT_PLAN_CODE=ONE-TIME
GISEBS_PAY_SUBSCRIPTION_PRODUCT_CODE=AGENT-SUB
GISEBS_PAY_PLAN_PROFESSIONAL=MONTHLY-PRO
GISEBS_PAY_PLAN_BUSINESS=MONTHLY-BUSINESS
GISEBS_PAY_PLAN_ENTERPRISE=MONTHLY-ENTERPRISE

# Polling optionnel après création de session (0 = pas de poll, checkout manuel)
GISEBS_PAY_POLL_ATTEMPTS=0
GISEBS_PAY_POLL_DELAY_SECONDS=2
GISEBS_PAY_REQUEST_TIMEOUT_SECONDS=30
