@model AgenticFactory.Web.Models.LoginViewModel
@{ ViewData["Title"] = "Connexion"; Layout = "_Layout"; }

<div class="af-auth-wrapper">
    <div class="af-auth-card">
        <div class="af-auth-logo">A</div>
        <h4 class="text-center fw-700 mb-1" style="font-weight:700;">Agentic Factory</h4>
        <p class="text-center text-muted mb-4" style="font-size:.875rem;">Accédez à votre espace architecte</p>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger py-2 mb-3" style="font-size:.85rem;">
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div>@error.ErrorMessage</div>
                }
            </div>
        }

        <form asp-action="Login" method="post">
            <div class="mb-3">
                <label class="form-label fw-500" style="font-size:.875rem;font-weight:500;">Email</label>
                <input asp-for="Email" class="form-control" placeholder="admin@entreprise.com" autocomplete="email" />
            </div>
            <div class="mb-4">
                <div class="d-flex justify-content-between mb-1">
                    <label class="form-label fw-500" style="font-size:.875rem;font-weight:500;">Mot de passe</label>
                </div>
                <input asp-for="Password" type="password" class="form-control" placeholder="••••••••" autocomplete="current-password" />
            </div>
            <button type="submit" class="btn btn-af-primary mb-3">
                Se connecter <i class="bi bi-arrow-right ms-1"></i>
            </button>
            <p class="text-center text-muted mb-0" style="font-size:.85rem;">
                Pas encore de compte ?
                <a asp-action="Register" style="color:#6366f1;font-weight:600;">Créer un compte</a>
            </p>
        </form>
    </div>
</div>
