@model AgenticFactory.Web.Models.AgentsIndexViewModel
@{
    ViewData["Title"] = "Agents";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-1">Agents</h2>
        <p class="text-muted mb-0">Créez et déployez vos agents IA.</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i> Nouvel agent
    </a>
</div>

@if (TempData["Success"] is string success)
{
    <div class="alert alert-success">@success</div>
}
@if (TempData["Error"] is string error)
{
    <div class="alert alert-danger">@error</div>
}
@if (TempData["ApiKey"] is string apiKey)
{
    <div class="alert alert-warning">
        <strong>Clé API (affichée une seule fois) :</strong>
        <code class="user-select-all">@apiKey</code>
    </div>
}

@if (!Model.Agents.Any())
{
    <div class="af-card text-center py-5">
        <i class="bi bi-robot display-4 text-muted"></i>
        <p class="mt-3 mb-3 text-muted">Aucun agent pour le moment.</p>
        <a asp-action="Create" class="btn btn-primary">Créer votre premier agent</a>
    </div>
}
else
{
    <div class="table-responsive af-card p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Nom</th>
                    <th>Endpoint</th>
                    <th>Statut</th>
                    <th>Créé le</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var agent in Model.Agents)
            {
                var isActive = agent.Status.Equals("Active", StringComparison.OrdinalIgnoreCase);
                <tr>
                    <td>
                        <strong>@agent.Name</strong>
                        <div class="small text-muted">@agent.Description</div>
                    </td>
                    <td><code class="small">@agent.EndpointSlug</code></td>
                    <td>
                        <span class="badge @(isActive ? "text-bg-success" : "text-bg-secondary")">@agent.Status</span>
                    </td>
                    <td>@agent.CreatedAtUtc.ToLocalTime().ToString("g")</td>
                    <td class="text-end">
                        @if (!isActive && agent.LatestBlueprintId.HasValue)
                        {
                            <form asp-action="Deploy" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="agentId" value="@agent.Id" />
                                <input type="hidden" name="blueprintId" value="@agent.LatestBlueprintId" />
                                <button type="submit" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-lightning"></i> Déployer
                                </button>
                            </form>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}
