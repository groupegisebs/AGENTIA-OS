@model AgenticFactory.Web.Models.AgentsIndexViewModel
@{
    ViewData["Title"] = "Mes Agents";
    var s = Model.Summary;
    var activePct = s.Total > 0 ? s.Active * 100.0 / s.Total : 0;
    var disabledPct = s.Total > 0 ? s.Disabled * 100.0 / s.Total : 0;
    var initials = string.Concat(Model.UserDisplayName.Split(' ', StringSplitOptions.RemoveEmptyEntries)
        .Take(2).Select(p => char.ToUpper(p[0])));
    var activity = Model.WeeklyActivity.Length > 0 ? Model.WeeklyActivity : new int[] { 0, 0, 0, 0, 0, 0, 0 };

    string StatusLabel(string display) => display switch
    {
        "Running" => "En cours",
        "Active" => "Actif",
        "Draft" => "En pause",
        "Disabled" => "Désactivé",
        _ => display
    };
    string StatusClass(string display) => display switch
    {
        "Running" => "running",
        "Active" => "active",
        "Draft" => "paused",
        "Disabled" => "disabled",
        _ => "draft"
    };
    string FormatLastRun(DateTime? dt)
    {
        if (dt is null) return "Jamais";
        var local = dt.Value.ToLocalTime();
        if (local.Date == DateTime.Today)
            return $"Aujourd'hui {local:HH:mm:ss}";
        if (local.Date == DateTime.Today.AddDays(-1))
            return $"Hier {local:HH:mm:ss}";
        return local.ToString("d MMM HH:mm");
    }
    bool IsRecentRun(DateTime? dt) =>
        dt.HasValue && dt.Value.ToLocalTime().Date >= DateTime.Today.AddDays(-1);
    string DisplayEnv(string env) =>
        env.Equals("—", StringComparison.Ordinal) ? "—" :
        char.ToUpper(env[0]) + env[1..].ToLowerInvariant();
    string EnvClass(string env) => env.Equals("production", StringComparison.OrdinalIgnoreCase) ? "prod"
        : env.Equals("staging", StringComparison.OrdinalIgnoreCase) ? "staging" : "other";
    string CategoryIcon(string cat) => cat switch
    {
        "Productivité" => "bi-envelope",
        "Documents" => "bi-file-earmark-text",
        "Support" => "bi-headset",
        "Analytics" => "bi-graph-up",
        "Sécurité" => "bi-shield-check",
        _ => "bi-robot"
    };
    string[] iconBgs = ["#eef2ff", "#fce7f3", "#dcfce7", "#fef3c7", "#dbeafe", "#f3e8ff"];
    string[] iconColors = ["#6366f1", "#db2777", "#16a34a", "#d97706", "#2563eb", "#9333ea"];

    string SparkSvg(int[] data, string stroke, string fill)
    {
        var max = Math.Max(1, data.DefaultIfEmpty(0).Max());
        var w = 120.0; var h = 36.0;
        var points = data.Select((v, i) =>
        {
            var x = data.Length <= 1 ? w / 2 : i * w / (data.Length - 1);
            var y = h - (v * h / max);
            return $"{x:0.#},{y:0.#}";
        });
        var line = string.Join(" ", points);
        var area = $"0,{h} {line} {w},{h}";
        return $"""<svg viewBox="0 0 {w} {h}" preserveAspectRatio="none"><polygon fill="{fill}" points="{area}"/><polyline fill="none" stroke="{stroke}" stroke-width="1.5" points="{line}"/></svg>""";
    }
}

<div class="agents-page">
    <nav class="agents-breadcrumb">
        <a asp-controller="Dashboard" asp-action="Index">Accueil</a>
        <span class="sep">›</span>
        <span>Agents</span>
    </nav>

    @if (TempData["Success"] is string success)
    {
        <div class="agents-alert alert alert-success">@success</div>
    }
    @if (TempData["Error"] is string error)
    {
        <div class="agents-alert alert alert-danger">@error</div>
    }
    @if (TempData["PublishPaymentAction"] is string payAction)
    {
        <div class="agents-alert alert alert-warning d-flex flex-wrap align-items-center justify-content-between gap-2">
            <span><i class="bi bi-credit-card me-1"></i> Paiement requis pour publier cet agent.</span>
            <form asp-action="PublishCheckout" method="post" class="m-0">
                @Html.AntiForgeryToken()
                <input type="hidden" name="checkoutAction" value="@payAction" />
                <input type="hidden" name="planId" value="@(TempData["PublishPaymentPlanId"])" />
                <button type="submit" class="btn btn-sm btn-warning">
                    @(payAction == "publish_credits" ? "Acheter des crédits de publication" : "Payer l'abonnement")
                </button>
            </form>
        </div>
    }
    @if (Model.PublishEligibility is { CanPublish: false } pub)
    {
        <div class="agents-alert alert alert-info">
            <i class="bi bi-info-circle me-1"></i>
            @pub.Message
            @if (!string.IsNullOrWhiteSpace(pub.CtaLabel))
            {
                <form asp-action="PublishCheckout" method="post" class="d-inline ms-2">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="checkoutAction" value="@pub.CheckoutAction" />
                    <input type="hidden" name="planId" value="@pub.SubscriptionPlanId" />
                    <button type="submit" class="btn btn-sm btn-outline-primary">@pub.CtaLabel</button>
                </form>
            }
        </div>
    }
    @if (TempData["ApiKey"] is string apiKey)
    {
        <div class="agents-alert alert alert-warning">
            <strong>Clé API (affichée une seule fois) :</strong>
            <code class="user-select-all">@apiKey</code>
        </div>
    }

    <div class="agents-page-head">
        <div class="agents-page-head-left">
            <h1>Mes Agents</h1>
            <p>Gérez, déployez et suivez tous vos agents IA.</p>
        </div>
        <div class="agents-page-head-right">
            @await Component.InvokeAsync("PlatformStatus")
            <button type="button" class="agents-notif-btn" title="Notifications">
                <i class="bi bi-bell"></i>
                @if (s.Running > 0)
                {
                    <span class="agents-notif-badge">@s.Running</span>
                }
            </button>
            <div class="agents-user-chip">
                <div class="agents-user-avatar">@initials</div>
                <div>
                    <div class="agents-user-name">@Model.UserDisplayName</div>
                    <div class="agents-user-role">@Model.UserRole</div>
                </div>
            </div>
            <a asp-action="Create" class="agents-btn-create">
                <i class="bi bi-plus-lg"></i> Créer un nouvel agent
            </a>
        </div>
    </div>

    <div class="agents-kpi-row">
        @{
            var kpis = new[]
            {
                ("Total Agents", s.Total, "Ce mois", "#6366f1", "rgba(99,102,241,.12)"),
                ("Agents Actifs", s.Active, $"{activePct:0}% du total", "#3b82f6", "rgba(59,130,246,.12)"),
                ("En Exécution", s.Running, "Maintenant", "#f97316", "rgba(249,115,22,.12)"),
                ("En Pause", s.Paused, "En attente", "#f59e0b", "rgba(245,158,11,.12)"),
                ("Désactivés", s.Disabled, $"{disabledPct:0.0}% du total", "#94a3b8", "rgba(148,163,184,.15)")
            };
        }
        @foreach (var (label, value, meta, color, fill) in kpis)
        {
            <div class="agents-kpi">
                <div class="agents-kpi-label">@label</div>
                <div class="agents-kpi-value">@value</div>
                <div class="agents-kpi-meta">@meta</div>
                <div class="agents-kpi-spark">@Html.Raw(SparkSvg(activity, color, fill))</div>
            </div>
        }
    </div>

    <div class="agents-toolbar">
        <div class="agents-search">
            <i class="bi bi-search"></i>
            <input type="search" id="agentSearch" placeholder="Rechercher un agent..." />
        </div>
        <div class="agents-filter">
            <select id="filterStatus">
                <option value="">Tous les statuts</option>
                <option value="Active">Actif</option>
                <option value="Running">En cours</option>
                <option value="Draft">En pause</option>
                <option value="Disabled">Désactivé</option>
            </select>
        </div>
        <div class="agents-filter">
            <select id="filterCategory">
                <option value="">Toutes les catégories</option>
                @foreach (var cat in Model.Agents.Select(a => a.Category).Distinct().OrderBy(c => c))
                {
                    <option value="@cat">@cat</option>
                }
            </select>
        </div>
        <div class="agents-filter">
            <select id="filterEnv">
                <option value="">Tous</option>
                @foreach (var env in Model.Agents.Select(a => a.Environment).Where(e => e != "—").Distinct())
                {
                    <option value="@env">@DisplayEnv(env)</option>
                }
            </select>
        </div>
        <button type="button" class="agents-btn-filters" id="toggleFilters" title="Filtres avancés">
            <i class="bi bi-sliders"></i> Filtres
        </button>
        <button type="button" class="agents-btn-reset" id="resetFilters">
            <i class="bi bi-arrow-counterclockwise"></i> Réinitialiser
        </button>
    </div>

    @if (!Model.Agents.Any())
    {
        <div class="agents-table-wrap">
            <div class="agents-empty">
                <i class="bi bi-robot d-block mb-3"></i>
                <p class="mb-3">Aucun agent pour le moment.</p>
                <a asp-action="Create" class="agents-btn-create">Créer votre premier agent</a>
            </div>
        </div>
    }
    else
    {
        <div class="agents-table-wrap">
            <div class="table-responsive">
                <table class="agents-table" id="agentsTable">
                    <thead>
                        <tr>
                            <th>Agent</th>
                            <th>Catégorie</th>
                            <th>Statut</th>
                            <th>Version</th>
                            <th>Environnement</th>
                            <th>Dernière exécution</th>
                            <th>Exécutions (7j)</th>
                            <th>Coût (30j)</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var agent in Model.Agents)
                    {
                        var idx = Math.Abs(agent.Name.GetHashCode()) % iconBgs.Length;
                        var maxSpark = Math.Max(1, agent.RunsSparkline.DefaultIfEmpty(0).Max());
                        var canDeploy = agent.DisplayStatus is "Draft" or "Disabled" && agent.LatestBlueprintId.HasValue;
                        var deployBlocked = canDeploy && Model.PublishEligibility is { CanPublish: false };
                        <tr data-name="@agent.Name.ToLowerInvariant() @agent.Description.ToLowerInvariant()"
                            data-status="@agent.DisplayStatus"
                            data-category="@agent.Category"
                            data-env="@agent.Environment">
                            <td>
                                <div class="agent-cell">
                                    <div class="agent-icon" style="background:@iconBgs[idx];color:@iconColors[idx]">
                                        <i class="bi @CategoryIcon(agent.Category)"></i>
                                    </div>
                                    <div>
                                        <div class="agent-name">@agent.Name</div>
                                        <div class="agent-desc">@agent.Description</div>
                                    </div>
                                </div>
                            </td>
                            <td><span class="agents-cat">@agent.Category</span></td>
                            <td><span class="agents-badge @StatusClass(agent.DisplayStatus)">@StatusLabel(agent.DisplayStatus)</span></td>
                            <td>@agent.VersionLabel</td>
                            <td><span class="agents-env @EnvClass(agent.Environment)">@DisplayEnv(agent.Environment)</span></td>
                            <td>
                                <span class="agents-last-run @(IsRecentRun(agent.LastRunAt) ? "recent" : "")">
                                    @FormatLastRun(agent.LastRunAt)
                                </span>
                            </td>
                            <td>
                                <div class="agents-spark-bars" title="@agent.RunsLast7Days exécutions">
                                    @foreach (var v in agent.RunsSparkline)
                                    {
                                        var h = (int)(v * 100.0 / maxSpark);
                                        if (h < 10 && v > 0) h = 10;
                                        <span style="height:@(h)%"></span>
                                    }
                                </div>
                            </td>
                            <td>
                                <span class="agents-cost">
                                    <strong>@agent.RunsLast30Days.ToString("N0")</strong> / $@agent.CostLast30Days.ToString("0.00")
                                </span>
                            </td>
                            <td>
                                <div class="agents-actions">
                                    @if (canDeploy && !deployBlocked)
                                    {
                                        <form asp-action="Deploy" method="post" class="d-inline deploy-confirm-form">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="agentId" value="@agent.Id" />
                                            <input type="hidden" name="blueprintId" value="@agent.LatestBlueprintId" />
                                            <button type="submit" class="agents-action-btn primary" title="Publier / Déployer"
                                                    data-confirm="Confirmer la publication de cet agent ? Un abonnement actif ou des crédits peuvent être requis.">
                                                <i class="bi bi-play-fill"></i>
                                            </button>
                                        </form>
                                    }
                                    else if (deployBlocked)
                                    {
                                        <button type="button" class="agents-action-btn" disabled
                                                title="@Model.PublishEligibility!.Message">
                                            <i class="bi bi-lock-fill"></i>
                                        </button>
                                    }
                                    else
                                    {
                                        <a asp-controller="Executions" asp-action="Index" class="agents-action-btn" title="Lancer / voir runs">
                                            <i class="bi bi-play-fill"></i>
                                        </a>
                                    }
                                    <a asp-controller="Executions" asp-action="Index" class="agents-action-btn" title="Statistiques">
                                        <i class="bi bi-bar-chart"></i>
                                    </a>
                                    <div class="dropdown">
                                        <button class="agents-action-btn" type="button" data-bs-toggle="dropdown">
                                            <i class="bi bi-three-dots-vertical"></i>
                                        </button>
                                        <ul class="dropdown-menu dropdown-menu-end shadow-sm">
                                            <li><span class="dropdown-item-text small text-muted font-monospace">@agent.EndpointSlug</span></li>
                                            <li><hr class="dropdown-divider" /></li>
                                            @if (canDeploy && !deployBlocked)
                                            {
                                                <li>
                                                    <form asp-action="Deploy" method="post" class="deploy-confirm-form">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="agentId" value="@agent.Id" />
                                                        <input type="hidden" name="blueprintId" value="@agent.LatestBlueprintId" />
                                                        <button type="submit" class="dropdown-item"><i class="bi bi-lightning me-2"></i>Publier / Déployer</button>
                                                    </form>
                                                </li>
                                            }
                                            else if (deployBlocked)
                                            {
                                                <li><span class="dropdown-item-text text-muted"><i class="bi bi-lock me-2"></i>@Model.PublishEligibility!.CtaLabel</span></li>
                                            }
                                            <li><a class="dropdown-item" asp-controller="Executions" asp-action="Index"><i class="bi bi-activity me-2"></i>Voir les exécutions</a></li>
                                            <li><a class="dropdown-item" asp-action="Create"><i class="bi bi-plus-circle me-2"></i>Créer un agent similaire</a></li>
                                        </ul>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
            <div class="agents-footer">
                <span id="agentsCount">Affichage 1 à @Math.Min(10, Model.Agents.Count) sur @Model.Agents.Count agents</span>
                <div class="d-flex align-items-center gap-3">
                    <select id="pageSize" class="form-select form-select-sm" style="width:auto;border-radius:8px;">
                        <option value="10">10 par page</option>
                        <option value="25">25 par page</option>
                        <option value="50">50 par page</option>
                    </select>
                    <div class="agents-pagination" id="pagination"></div>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
<script>
(() => {
    const rows = [...document.querySelectorAll('#agentsTable tbody tr')];
    if (!rows.length) return;

    const search = document.getElementById('agentSearch');
    const filterStatus = document.getElementById('filterStatus');
    const filterCategory = document.getElementById('filterCategory');
    const filterEnv = document.getElementById('filterEnv');
    const resetBtn = document.getElementById('resetFilters');
    const pageSizeEl = document.getElementById('pageSize');
    const pagination = document.getElementById('pagination');
    const countEl = document.getElementById('agentsCount');
    let page = 1;

    function filtered() {
        const q = (search?.value || '').trim().toLowerCase();
        const st = filterStatus?.value || '';
        const cat = filterCategory?.value || '';
        const env = filterEnv?.value || '';
        return rows.filter(r => {
            if (q && !r.dataset.name.includes(q)) return false;
            if (st && r.dataset.status !== st) return false;
            if (cat && r.dataset.category !== cat) return false;
            if (env && r.dataset.env !== env) return false;
            return true;
        });
    }

    function render() {
        const size = parseInt(pageSizeEl?.value || '10', 10);
        const visible = filtered();
        const totalPages = Math.max(1, Math.ceil(visible.length / size));
        if (page > totalPages) page = totalPages;
        rows.forEach(r => r.style.display = 'none');
        const start = (page - 1) * size;
        visible.slice(start, start + size).forEach(r => r.style.display = '');
        const end = Math.min(start + size, visible.length);
        if (countEl) {
            countEl.textContent = visible.length
                ? `Affichage ${visible.length ? start + 1 : 0} à ${end} sur ${visible.length} agents`
                : 'Aucun agent correspondant';
        }
        if (!pagination) return;
        pagination.innerHTML = '';
        const mk = (label, p, disabled = false) => {
            const b = document.createElement('button');
            b.className = 'agents-page-btn' + (p === page ? ' active' : '');
            b.textContent = label;
            b.disabled = disabled;
            if (!disabled) b.onclick = () => { page = p; render(); };
            pagination.appendChild(b);
        };
        mk('‹', page - 1, page <= 1);
        const maxBtns = Math.min(totalPages, 5);
        for (let i = 1; i <= maxBtns; i++) mk(String(i), i);
        mk('›', page + 1, page >= totalPages);
    }

    [search, filterStatus, filterCategory, filterEnv, pageSizeEl].forEach(el => {
        el?.addEventListener('input', () => { page = 1; render(); });
        el?.addEventListener('change', () => { page = 1; render(); });
    });
    resetBtn?.addEventListener('click', () => {
        if (search) search.value = '';
        [filterStatus, filterCategory, filterEnv].forEach(el => { if (el) el.value = ''; });
        page = 1; render();
    });
    render();
    document.querySelectorAll('.deploy-confirm-form').forEach(form => {
        form.addEventListener('submit', e => {
            const btn = form.querySelector('button[data-confirm]');
            const msg = btn?.dataset.confirm;
            if (msg && !window.confirm(msg)) e.preventDefault();
        });
    });
})();
</script>
}
