@model AgenticFactory.Web.Models.CreateAgentViewModel
@using AgenticFactory.Web.Models
@using System.Text.Json
@{
    ViewData["Title"] = "Créer un nouvel agent";
    var studioDomains = ViewData["StudioDomains"] as IReadOnlyList<StudioDomainItem> ?? StudioCatalog.Domains;
    var displayName = User.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value
        ?? User.Identity?.Name ?? "Utilisateur";
    var role = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "Utilisateur";
    var initials = string.Concat(displayName.Split(' ', StringSplitOptions.RemoveEmptyEntries)
        .Take(2).Select(p => char.ToUpper(p[0])));
}

<div class="studio-page">
    <div class="studio-page-top">
        <nav class="studio-breadcrumb">
            <a asp-controller="Dashboard" asp-action="Index">Accueil</a>
            <span class="sep">›</span>
            <a asp-action="Index">Agents</a>
            <span class="sep">›</span>
            <span>Créer un nouvel agent</span>
        </nav>
        <div class="studio-page-head-right">
            @await Component.InvokeAsync("PlatformStatus")
            <button type="button" class="studio-notif-btn" title="Notifications">
                <i class="bi bi-bell"></i>
            </button>
            <div class="studio-user-chip">
                <div class="studio-user-avatar">@initials</div>
                <div>
                    <div class="studio-user-name">@displayName</div>
                    <div class="studio-user-role">@role</div>
                </div>
            </div>
        </div>
    </div>

    <header class="studio-header">
        <h1>Créer un agent Runtime Agentic</h1>
        <p>Définissez un collaborateur IA autonome — même boucle d'exécution pour tous les agents.</p>
        <div class="studio-agentic-loop-bar" id="agenticLoop" aria-label="Boucle agentique"></div>
    </header>

    <form id="studioForm" asp-controller="Agents" asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Message" id="hiddenMessage" />
        <input type="hidden" asp-for="WizardJson" id="hiddenWizardJson" />
        <input type="hidden" asp-for="DesignerWorkflow" id="hiddenDesignerWorkflow" />
        <input type="hidden" id="creationModeInput" name="creationModeInput" value="guided" />

        <div class="creation-mode-selector">
            <div class="creation-mode-selector-intro">Choisissez votre méthode de création</div>
            <div class="creation-mode-card active" data-mode="guided">
                <div class="creation-mode-card-icon"><i class="bi bi-list-ol"></i></div>
                <div class="creation-mode-card-body">
                    <div class="creation-mode-card-title">Assistant guidé</div>
                    <div class="creation-mode-card-desc">Configurez votre agent étape par étape avec le wizard 10 phases : Mission, Sensors, Skills, Tools, Actuators, Decision, Memory, Runtime, Sécurité, Blueprint.</div>
                    <span class="creation-mode-card-badge">Recommandé</span>
                </div>
            </div>
            <div class="creation-mode-card" data-mode="designer">
                <div class="creation-mode-card-icon"><i class="bi bi-diagram-3"></i></div>
                <div class="creation-mode-card-body">
                    <div class="creation-mode-card-title">Designer visuel</div>
                    <div class="creation-mode-card-desc">Dessinez votre workflow agent sur un canvas interactif. Glissez-déposez des nœuds, connectez-les et configurez chaque composant visuellement.</div>
                    <span class="creation-mode-card-badge">Nouveau</span>
                </div>
            </div>
        </div>

        <div id="wizardContainer">
        <div class="studio-layout">
            <div class="studio-main">
                <div class="studio-stepper-wrap">
                    <div class="studio-stepper studio-stepper-10" id="stepper">
                        @{
                            var steps = new[] {
                                ("Mission", "Rôle"),
                                ("Sensors", "Observe"),
                                ("Skills", "Understand"),
                                ("Tools", "Capacités"),
                                ("Actuators", "Act"),
                                ("Decision", "Decide"),
                                ("Memory", "Contexte"),
                                ("Runtime", "Exécution"),
                                ("Security", "Règles"),
                                ("Blueprint", "Résumé")
                            };
                            for (var i = 0; i < steps.Length; i++)
                            {
                                var n = i + 1;
                                <div class="studio-stepper-item@(n == 1 ? " active" : "")" data-step="@n">
                                    <div class="studio-stepper-circle">@n</div>
                                    <div class="studio-stepper-title">@steps[i].Item1</div>
                                    <div class="studio-stepper-sub">@steps[i].Item2</div>
                                </div>
                            }
                        }
                    </div>
                </div>

                <div class="studio-wizard-card">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="studio-step-panel active" id="stepPanel1">
                        <h2 class="studio-step-title">1. Mission — rôle et objectif de l'agent</h2>
                        <p class="studio-step-hint">Décrivez ce que votre agent doit accomplir. Le domaine métier est un contexte optionnel, pas l'architecture.</p>
                        <label class="studio-nl-label" for="missionText">Mission *</label>
                        <textarea class="studio-freetext studio-mission-text" id="missionText" maxlength="2000" rows="4"
                                  placeholder="Ex : Agent comptable qui surveille la boîte factures@@entreprise.com, extrait les données des PDF, les valide et les envoie dans CogniDoc."></textarea>
                        <div class="studio-subsection studio-mission-context">
                            <label class="studio-nl-label" for="missionContext">Contexte métier <span class="studio-nl-hint">(optionnel)</span></label>
                            <textarea class="studio-freetext" id="missionContext" maxlength="1000" rows="2"
                                      placeholder="Secteur, contraintes réglementaires, équipes concernées…"></textarea>
                        </div>
                        <div class="studio-subsection">
                            <label class="studio-nl-label">Domaine métier <span class="studio-nl-hint">(tag optionnel)</span></label>
                            <div class="studio-chip-grid" id="domainTags"></div>
                        </div>
                        <div class="studio-nl-section">
                            <label class="studio-nl-label" for="freeText">Notes complémentaires <span class="studio-nl-hint">(optionnel)</span></label>
                            <textarea class="studio-freetext" id="freeText" maxlength="2000" rows="2"
                                      placeholder="Précisions, exemples, contraintes…"></textarea>
                            <div class="studio-char-count"><span id="charCount">0</span> / 2000</div>
                        </div>
                        <div class="studio-validation-msg" id="validationMsg"></div>
                    </div>

                    <div class="studio-step-panel" id="stepPanel2">
                        <h2 class="studio-step-title">2. Sensors — d'où l'agent observe</h2>
                        <p class="studio-step-hint">Sélectionnez vos sources de données puis configurez les connexions (OAuth, API, credentials…).</p>
                        <div id="sensorGrid"></div>
                        <div class="studio-source-config-panel" id="sensorConfigPanel"></div>
                    </div>

                    <div class="studio-step-panel" id="stepPanel3">
                        <h2 class="studio-step-title">3. Skills — comment l'agent comprend</h2>
                        <p class="studio-step-hint">Capacités cognitives : OCR, extraction, classification, RAG, etc.</p>
                        <div id="skillGrid"></div>
                        <div class="studio-source-config-panel" id="skillConfigPanel"></div>
                    </div>

                    <div class="studio-step-panel" id="stepPanel4">
                        <h2 class="studio-step-title">4. Tools — avec quoi l'agent agit</h2>
                        <p class="studio-step-hint">Intégrations et outils disponibles pendant l'exécution.</p>
                        <div id="toolGrid"></div>
                        <div class="studio-source-config-panel" id="toolConfigPanel"></div>
                    </div>

                    <div class="studio-step-panel" id="stepPanel5">
                        <h2 class="studio-step-title">5. Actuators — ce que l'agent produit</h2>
                        <p class="studio-step-hint">Actions concrètes en sortie : emails, tickets, fichiers, API…</p>
                        <div id="actuatorGrid"></div>
                        <div class="studio-source-config-panel" id="actuatorConfigPanel"></div>
                    </div>

                    <div class="studio-step-panel" id="stepPanel6">
                        <h2 class="studio-step-title">6. Decision Engine — comment l'agent décide</h2>
                        <p class="studio-step-hint">Moteur de raisonnement : LLM, règles métier, validation humaine ou hybride.</p>
                        <div class="studio-exec-trigger-grid studio-decision-grid" id="decisionGrid"></div>
                        <div id="decisionConfigPanel"></div>
                    </div>

                    <div class="studio-step-panel" id="stepPanel7">
                        <h2 class="studio-step-title">7. Memory — ce que l'agent retient</h2>
                        <p class="studio-step-hint">Types de mémoire persistante pour le contexte et l'apprentissage.</p>
                        <div class="studio-objective-grid" id="memoryGrid"></div>
                        <div id="memoryConfigPanel"></div>
                    </div>

                    <div class="studio-step-panel" id="stepPanel8">
                        <h2 class="studio-step-title"><i class="bi bi-gear-wide-connected"></i> 8. Execution Runtime</h2>
                        <p class="studio-step-hint">Déclencheur, runtime (Windows, Docker, K8s, Azure, AWS, OVH), résilience, logs et OpenTelemetry.</p>
                        <div id="executionPanel"></div>
                    </div>

                    <div class="studio-step-panel" id="stepPanel9">
                        <h2 class="studio-step-title">9. Security — règles et conformité</h2>
                        <p class="studio-step-hint">Permissions, secrets, audit et validation humaine.</p>
                        <div class="studio-check-grid cols-3" id="securityGrid"></div>
                    </div>

                    <div class="studio-step-panel" id="stepPanel10">
                        <h2 class="studio-step-title"><i class="bi bi-diagram-3"></i> 10. Blueprint — workflow final</h2>
                        <p class="studio-step-hint">Visualisez l'ensemble de votre agent — boucle agentique, capacités et runtime — puis modifiez une section ou générez le blueprint.</p>
                        <div id="finalReview"></div>
                    </div>

                    <div class="studio-footer">
                        <div class="studio-footer-left">
                            <button type="button" class="studio-btn studio-btn-ghost" id="btnPrev" style="display:none">
                                <i class="bi bi-arrow-left"></i> Retour
                            </button>
                            <a asp-action="Index" class="studio-btn studio-btn-ghost">Annuler</a>
                        </div>
                        <div class="studio-footer-right">
                            <button type="button" class="studio-btn studio-btn-outline" id="btnDraft">
                                Enregistrer comme brouillon
                            </button>
                            <button type="button" class="studio-btn studio-btn-primary" id="btnNext">
                                Suivant <i class="bi bi-arrow-right"></i>
                            </button>
                            <button type="submit" class="studio-btn studio-btn-primary" id="btnGenerate" hidden style="display:none">
                                <i class="bi bi-stars"></i> Générer le Blueprint
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <aside class="studio-blueprint-panel">
                <div class="studio-blueprint-card">
                    <div class="studio-blueprint-head">
                        <h3><i class="bi bi-magic"></i> Blueprint en construction</h3>
                        <span class="studio-bp-status-badge">En construction</span>
                    </div>
                    <div class="studio-blueprint-body">
                        <div class="studio-bp-field">
                            <div class="studio-bp-label">Nom proposé</div>
                            <div class="studio-bp-name-row">
                                <span class="studio-bp-value" id="bp-name">Runtime Agent</span>
                                <button type="button" class="studio-bp-edit" id="bpEditName" title="Modifier le nom">
                                    <i class="bi bi-pencil"></i>
                                </button>
                            </div>
                        </div>
                        <div class="studio-bp-field">
                            <div class="studio-bp-label">Mission</div>
                            <div class="studio-bp-value undefined" id="bp-mission">— Non défini —</div>
                        </div>
                        <div class="studio-bp-field">
                            <div class="studio-bp-label">Sensors</div>
                            <div class="studio-bp-value undefined" id="bp-sensors">— Non défini —</div>
                        </div>
                        <div class="studio-bp-field">
                            <div class="studio-bp-label">Skills</div>
                            <div class="studio-bp-value undefined" id="bp-skills">— Non défini —</div>
                        </div>
                        <div class="studio-bp-field">
                            <div class="studio-bp-label">Tools</div>
                            <div class="studio-bp-value undefined" id="bp-tools">— Non défini —</div>
                        </div>
                        <div class="studio-bp-field">
                            <div class="studio-bp-label">Actions (Actuators)</div>
                            <div class="studio-bp-value undefined" id="bp-actuators">— Non défini —</div>
                        </div>
                        <div class="studio-bp-field">
                            <div class="studio-bp-label">Memory</div>
                            <div class="studio-bp-value undefined" id="bp-memory">— Non défini —</div>
                        </div>
                        <div class="studio-bp-field">
                            <div class="studio-bp-label">Moteur IA</div>
                            <div class="studio-bp-value undefined" id="bp-decision">— Non défini —</div>
                        </div>
                        <div class="studio-bp-field">
                            <div class="studio-bp-label">Runtime</div>
                            <div class="studio-bp-value undefined" id="bp-trigger">— Non défini —</div>
                        </div>
                        <div class="studio-bp-field">
                            <div class="studio-bp-label">Boucle agentique</div>
                            <div class="studio-bp-loop-preview" id="bp-agentic-loop">Observe → Understand → Decide → Act → Verify → Log → Wait</div>
                        </div>
                        <div class="studio-bp-field studio-bp-wf-condensed-wrap" id="bp-workflow-condensed-wrap" hidden>
                            <div class="studio-bp-label">Workflow condensé</div>
                            <div id="bp-workflow-condensed"></div>
                        </div>
                        <div class="studio-runtime-preview-card" id="runtimePreviewCard"></div>
                        <div class="studio-bp-field">
                            <div class="studio-bp-label">Complexité estimée</div>
                            <div class="studio-bp-stars" id="bp-complexity">
                                <span>★</span><span>★</span><span>★</span><span>★</span><span>★</span>
                            </div>
                        </div>
                        <div class="studio-bp-field">
                            <div class="studio-bp-label">Coût estimé (IA)</div>
                            <div class="studio-bp-cost" id="bp-cost">$0.00 / mois</div>
                        </div>
                        <div class="studio-bp-field">
                            <div class="studio-bp-label">Temps de création</div>
                            <div class="studio-bp-value" id="bp-creation-time">~5 min</div>
                        </div>
                        <div class="studio-bp-field">
                            <div class="studio-bp-label">Consommation IA</div>
                            <div class="studio-bp-value" id="bp-ai-model">gpt-4o-mini</div>
                        </div>
                        <div class="studio-bp-field">
                            <div class="studio-bp-label">Runtime cible</div>
                            <div id="bp-runtime"><span class="studio-bp-pill blue">Windows Service</span></div>
                        </div>
                        <div class="studio-bp-field">
                            <div class="studio-bp-label">Statut</div>
                            <div id="bp-status"><span class="studio-bp-pill amber">En construction</span></div>
                        </div>
                    </div>
                    <div class="studio-bp-empty" id="bp-empty">
                        <div class="studio-bp-empty-icon"><i class="bi bi-diagram-3"></i></div>
                        <p>Décrivez la mission pour voir le blueprint de votre agent.</p>
                    </div>
                </div>
            </aside>
        </div>
    </div>
    </form>

    <!-- ── Visual Designer Container ─────────────────────────── -->
    <div class="designer-container" id="designerContainer">
        <div id="designerValidationBanner" class="designer-validation-banner"></div>
        <div class="designer-layout">
            <!-- Palette -->
            <div class="designer-palette" id="designerPaletteContainer">
                <div class="designer-palette-header">Composants</div>
                <div class="designer-palette-search">
                    <input type="text" id="paletteSearchInput" placeholder="Rechercher…" />
                </div>
                <div class="designer-palette-sections"></div>
            </div>
            <!-- Canvas area -->
            <div class="designer-canvas-area">
                <!-- Agent meta fields -->
                <div class="designer-canvas-meta">
                    <div class="designer-canvas-meta-row">
                        <input type="text" id="designerAgentName" placeholder="Nom de l'agent" />
                        <textarea id="designerMission" placeholder="Mission de l'agent" rows="2"></textarea>
                    </div>
                    <div class="designer-canvas-meta-domains" id="designerDomainsRow"></div>
                </div>
                <!-- Toolbar -->
                <div class="designer-canvas-toolbar">
                    <button class="designer-toolbar-btn" id="designerBtnDeselect" title="Annuler la sélection">
                        <i class="bi bi-cursor"></i> Déselect.
                    </button>
                    <button class="designer-toolbar-btn" id="designerBtnDelete" title="Supprimer nœud(s)">
                        <i class="bi bi-trash"></i> Supprimer
                    </button>
                    <div class="designer-toolbar-divider"></div>
                    <button class="designer-toolbar-btn" id="designerBtnZoomIn" title="Zoom +">
                        <i class="bi bi-zoom-in"></i>
                    </button>
                    <button class="designer-toolbar-btn" id="designerBtnZoomOut" title="Zoom -">
                        <i class="bi bi-zoom-out"></i>
                    </button>
                    <button class="designer-toolbar-btn" id="designerBtnFit" title="Ajuster la vue">
                        <i class="bi bi-fullscreen"></i> Ajuster
                    </button>
                    <div class="designer-toolbar-divider"></div>
                    <button class="designer-toolbar-btn danger" id="designerBtnClear" title="Vider le canvas">
                        <i class="bi bi-eraser"></i> Vider
                    </button>
                    <button class="designer-toolbar-btn primary" id="designerBtnBlueprint">
                        <i class="bi bi-stars"></i> Générer le Blueprint
                    </button>
                    <span class="designer-toolbar-stats" id="designerToolbarStats">0 nœuds · 0 connexions</span>
                </div>
                <!-- Canvas -->
                <div class="designer-canvas-wrap" id="designerCanvasWrap">
                    <svg class="designer-canvas-svg" id="designerCanvasSvg" xmlns="http://www.w3.org/2000/svg"></svg>
                    <div class="designer-canvas-nodes" id="designerCanvasNodes"></div>
                    <!-- Minimap -->
                    <div class="designer-minimap" id="designerMinimap">
                        <svg class="designer-minimap-svg" id="designerMinimapSvg" xmlns="http://www.w3.org/2000/svg"></svg>
                        <span class="designer-minimap-label">Minimap</span>
                    </div>
                </div>
            </div>
            <!-- Properties panel -->
            <div class="designer-properties">
                <div class="designer-properties-header">
                    <span class="designer-properties-title"><i class="bi bi-sliders"></i> Propriétés</span>
                </div>
                <div class="designer-properties-empty" id="designerPropEmpty">
                    <div class="designer-properties-empty-icon"><i class="bi bi-cursor-text"></i></div>
                    <div class="designer-properties-empty-text">Sélectionnez un nœud pour configurer ses propriétés</div>
                </div>
                <div class="designer-properties-body" id="designerPropBody" style="display:none;flex-direction:column;gap:12px;"></div>
            </div>
        </div>
    </div>

    <!-- Blueprint review overlay (designer mode) -->
    <div class="designer-blueprint-overlay" id="designerBlueprintOverlay">
        <div class="designer-blueprint-modal">
            <div class="designer-blueprint-modal-header">
                <div class="designer-blueprint-modal-title">
                    <i class="bi bi-diagram-3"></i> Blueprint — Révision finale
                </div>
                <button type="button" class="designer-blueprint-modal-close" id="designerBlueprintClose">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
            <div class="designer-blueprint-modal-body" id="designerBlueprintBody"></div>
            <div class="designer-blueprint-modal-footer">
                <button type="button" class="designer-toolbar-btn" id="designerBlueprintEdit">
                    <i class="bi bi-pencil"></i> Modifier le designer
                </button>
                <button type="button" class="designer-toolbar-btn primary" id="designerBlueprintSubmit">
                    <i class="bi bi-stars"></i> Générer l'agent
                </button>
            </div>
        </div>
    </div>

    <div class="studio-draft-toast" id="draftToast">Brouillon enregistré localement</div>
</div>

<div class="studio-modal-backdrop" id="catalogConfigModalBackdrop" role="dialog" aria-modal="true" aria-labelledby="catalogConfigModalTitle">
    <div class="studio-modal studio-config-modal">
        <div class="studio-modal-head studio-config-modal-head">
            <div class="studio-config-modal-title-row">
                <span class="studio-config-modal-icon" id="catalogConfigModalIcon"><i class="bi bi-plug"></i></span>
                <div class="studio-config-modal-title-text">
                    <h3 id="catalogConfigModalTitle">Paramètres de connexion</h3>
                    <p>Les identifiants sensibles seront stockés chiffrés dans <strong>Agentia Vault</strong>.</p>
                </div>
                <span class="studio-config-progress" id="catalogConfigModalProgress">0/0 renseigné(s)</span>
            </div>
            <select class="studio-config-modal-selector d-none" id="catalogConfigModalSelector" aria-label="Élément à configurer"></select>
        </div>
        <div class="studio-modal-body studio-config-modal-body" id="catalogConfigModalBody"></div>
        <div class="studio-modal-foot">
            <button type="button" class="studio-btn studio-btn-ghost" id="catalogConfigModalClose">Fermer</button>
            <button type="button" class="studio-btn studio-btn-primary" id="catalogConfigModalSave">
                <i class="bi bi-check-lg"></i> Enregistrer
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="~/css/agentia-designer.css" asp-append-version="true" />
    <script>
        window.STUDIO_DOMAINS = @Html.Raw(JsonSerializer.Serialize(studioDomains.Select(d => new {
            id = d.Id, icon = d.Icon, bg = d.Bg, color = d.Color,
            name = d.Name, desc = d.Desc, namePrefix = d.NamePrefix, defaultAgent = d.DefaultAgent
        })));
    </script>
    <script src="~/js/agentia-studio-sensors.js" asp-append-version="true"></script>
    <script src="~/js/agentia-studio-skills.js" asp-append-version="true"></script>
    <script src="~/js/agentia-studio-tools.js" asp-append-version="true"></script>
    <script src="~/js/agentia-studio-actuators.js" asp-append-version="true"></script>
    <script src="~/js/agentia-studio-execution-providers.js" asp-append-version="true"></script>
    <script src="~/js/agentia-studio-decision.js" asp-append-version="true"></script>
    <script src="~/js/agentia-studio-memory.js" asp-append-version="true"></script>
    <script src="~/js/agentia-studio-runtime.js" asp-append-version="true"></script>
    <script src="~/js/agentia-studio.js" asp-append-version="true"></script>
    <script src="~/js/agentia-studio-designer.js" asp-append-version="true"></script>
}
