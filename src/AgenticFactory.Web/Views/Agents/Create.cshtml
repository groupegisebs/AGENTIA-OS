@model AgenticFactory.Web.Models.CreateAgentViewModel
@{
    ViewData["Title"] = "Nouvel agent";
}

<div class="agents-page">
    <nav class="agents-breadcrumb">
        <a asp-controller="Dashboard" asp-action="Index">Accueil</a>
        <span class="sep">›</span>
        <a asp-action="Index">Agents</a>
        <span class="sep">›</span>
        <span>Créer</span>
    </nav>

    <div class="agents-create-page">
        <h2>Créer un nouvel agent</h2>
        <p class="text-muted mb-4">Décrivez en langage naturel ce que l'agent doit faire. Un blueprint sera généré automatiquement.</p>

        <div class="agents-create-card">
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <div class="mb-3">
                    <label asp-for="Message" class="form-label fw-semibold">Description de l'agent</label>
                    <textarea asp-for="Message" class="form-control" rows="6"
                              placeholder="Ex : Un agent qui analyse les emails entrants, extrait les pièces jointes et propose une réponse professionnelle en français."></textarea>
                    <span asp-validation-for="Message" class="text-danger small"></span>
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="agents-btn-create border-0">
                        <i class="bi bi-stars"></i> Générer le blueprint
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Annuler</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
