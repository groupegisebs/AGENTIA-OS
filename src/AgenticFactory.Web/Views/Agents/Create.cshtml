@model AgenticFactory.Web.Models.CreateAgentViewModel
@using AgenticFactory.Web.Models
@using System.Text.Json
@{
    ViewData["Title"] = "Créer un nouvel agent";
    var studioDomains = ViewData["StudioDomains"] as IReadOnlyList<StudioDomainItem> ?? StudioCatalog.Domains;
    var displayName = User.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value
        ?? User.Identity?.Name ?? "Utilisateur";
    var role = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "Utilisateur";
    var initials = string.Concat(displayName.Split(' ', StringSplitOptions.RemoveEmptyEntries)
        .Take(2).Select(p => char.ToUpper(p[0])));
}

<div class="studio-page">
    <div class="studio-page-top">
        <nav class="studio-breadcrumb">
            <a asp-controller="Dashboard" asp-action="Index">Accueil</a>
            <span class="sep">›</span>
            <a asp-action="Index">Agents</a>
            <span class="sep">›</span>
            <span>Créer un nouvel agent</span>
        </nav>
        <div class="studio-page-head-right">
            @await Component.InvokeAsync("PlatformStatus")
            <button type="button" class="studio-notif-btn" title="Notifications">
                <i class="bi bi-bell"></i>
            </button>
            <div class="studio-user-chip">
                <div class="studio-user-avatar">@initials</div>
                <div>
                    <div class="studio-user-name">@displayName</div>
                    <div class="studio-user-role">@role</div>
                </div>
            </div>
        </div>
    </div>

    <header class="studio-header">
        <h1>Créer un nouvel agent IA</h1>
        <p>Suivez les étapes pour décrire votre agent. Nous générerons automatiquement le blueprint.</p>
    </header>

    <form id="studioForm" asp-controller="Agents" asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Message" id="hiddenMessage" />
        <input type="hidden" asp-for="WizardJson" id="hiddenWizardJson" />

        <div class="studio-layout">
            <div class="studio-main">
                <div class="studio-stepper-wrap">
                    <div class="studio-stepper" id="stepper">
                        <div class="studio-stepper-item active" data-step="1">
                            <div class="studio-stepper-circle">1</div>
                            <div class="studio-stepper-title">Domaine</div>
                            <div class="studio-stepper-sub">Métier</div>
                        </div>
                        <div class="studio-stepper-item" data-step="2">
                            <div class="studio-stepper-circle">2</div>
                            <div class="studio-stepper-title">Objectif</div>
                            <div class="studio-stepper-sub">Mission</div>
                        </div>
                        <div class="studio-stepper-item" data-step="3">
                            <div class="studio-stepper-circle">3</div>
                            <div class="studio-stepper-title">Données</div>
                            <div class="studio-stepper-sub">Sources</div>
                        </div>
                        <div class="studio-stepper-item" data-step="4">
                            <div class="studio-stepper-circle">4</div>
                            <div class="studio-stepper-title">Actions</div>
                            <div class="studio-stepper-sub">Tâches</div>
                        </div>
                        <div class="studio-stepper-item" data-step="5">
                            <div class="studio-stepper-circle">5</div>
                            <div class="studio-stepper-title">Exécution</div>
                            <div class="studio-stepper-sub">Runtime</div>
                        </div>
                        <div class="studio-stepper-item" data-step="6">
                            <div class="studio-stepper-circle">6</div>
                            <div class="studio-stepper-title">Autonomie</div>
                            <div class="studio-stepper-sub">Niveau</div>
                        </div>
                        <div class="studio-stepper-item" data-step="7">
                            <div class="studio-stepper-circle">7</div>
                            <div class="studio-stepper-title">Sécurité</div>
                            <div class="studio-stepper-sub">Règles</div>
                        </div>
                        <div class="studio-stepper-item" data-step="8">
                            <div class="studio-stepper-circle">8</div>
                            <div class="studio-stepper-title">Blueprint</div>
                            <div class="studio-stepper-sub">Résumé</div>
                        </div>
                    </div>
                </div>

                <div class="studio-wizard-card">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="studio-step-panel active" id="stepPanel1">
                        <h2 class="studio-step-title">1. Choisissez le domaine métier de votre agent</h2>
                        <div class="studio-domain-grid" id="domainGrid">
                            @foreach (var d in studioDomains)
                            {
                                <button type="button" class="studio-domain-card@(d.Id == "email" ? " selected" : "")" data-domain="@d.Id">
                                    <span class="studio-domain-check"><i class="bi bi-check"></i></span>
                                    <div class="studio-domain-icon-wrap" style="background:@d.Bg;color:@d.Color">
                                        <i class="bi @d.Icon"></i>
                                    </div>
                                    <div class="studio-domain-name">@d.Name</div>
                                    <div class="studio-domain-desc">@d.Desc</div>
                                </button>
                            }
                            <button type="button" class="studio-domain-card studio-domain-request" data-action="request-domain">
                                <div class="studio-domain-request-icon"><i class="bi bi-plus-lg"></i></div>
                                <div class="studio-domain-name">Demander un domaine</div>
                                <div class="studio-domain-desc">Proposez un nouveau domaine métier à l'équipe Agentia</div>
                            </button>
                        </div>
                        <div class="studio-domain-request-bar">
                            <p>Vous ne trouvez pas votre secteur d'activité ?</p>
                            <button type="button" class="studio-btn-request" id="btnRequestDomain">
                                Demander l'ajout d'un domaine <i class="bi bi-arrow-right"></i>
                            </button>
                        </div>
                        <div class="studio-nl-section">
                            <label class="studio-nl-label" for="freeText">
                                Décrivez votre besoin en langage naturel
                                <span class="studio-nl-hint">(optionnel mais recommandé)</span>
                            </label>
                            <textarea class="studio-freetext" id="freeText" maxlength="2000" rows="3"
                                      placeholder="Ex : Je veux un agent qui lit mes emails Outlook, détecte les factures PDF, extrait les informations importantes, les envoie dans CogniDoc puis notifie le comptable."></textarea>
                            <div class="studio-char-count"><span id="charCount">0</span> / 2000</div>
                        </div>
                        <div class="studio-validation-msg" id="validationMsg"></div>
                    </div>

                    <div class="studio-step-panel" id="stepPanel2">
                        <h2 class="studio-step-title">2. Quel est l'objectif principal de l'agent ?</h2>
                        <p class="studio-step-hint">Sélectionnez un ou plusieurs objectifs. Les options marquées « Recommandé » correspondent à votre domaine.</p>
                        <div class="studio-objective-grid" id="objectiveGrid"></div>
                        <div class="studio-domain-request-bar">
                            <p>L'objectif recherché n'est pas dans la liste ?</p>
                            <button type="button" class="studio-btn-request" id="btnRequestObjective">
                                Demander l'ajout d'un objectif <i class="bi bi-arrow-right"></i>
                            </button>
                        </div>
                    </div>

                    <div class="studio-step-panel" id="stepPanel3">
                        <h2 class="studio-step-title">3. Où trouvent les données ?</h2>
                        <p class="studio-step-hint">Sélectionnez vos sources puis renseignez les paramètres de connexion (SMTP, OAuth, API tokens, credentials…).</p>
                        <div id="sourceGrid"></div>
                        <div class="studio-source-config-panel" id="sourceConfigPanel"></div>
                    </div>

                    <div class="studio-step-panel" id="stepPanel4">
                        <h2 class="studio-step-title">4. Que doit faire l'agent ?</h2>
                        <p class="studio-step-hint">Sélectionnez les actions du workflow puis renseignez leurs paramètres (destinataires, templates, règles, endpoints…).</p>
                        <div id="actionGrid"></div>
                        <div class="studio-source-config-panel" id="actionConfigPanel"></div>
                    </div>

                    <div class="studio-step-panel" id="stepPanel5">
                        <h2 class="studio-step-title"><i class="bi bi-gear-wide-connected"></i> 5. Configuration d'exécution</h2>
                        <p class="studio-step-hint">Configurez le moteur d'exécution de l'agent : déclencheur, runtime, résilience, logs et supervision — comme un service Windows complet.</p>
                        <div id="executionPanel"></div>
                    </div>

                    <div class="studio-step-panel" id="stepPanel6">
                        <h2 class="studio-step-title">6. Quel niveau d'autonomie ?</h2>
                        <div class="studio-autonomy-wrap">
                            <div class="studio-autonomy-label-row">
                                <span>Assistant</span>
                                <span>Superviseur multi-agent</span>
                            </div>
                            <div class="studio-autonomy-track">
                                <div class="studio-autonomy-fill" id="autonomyFill" style="width:25%"></div>
                            </div>
                            <input type="range" class="studio-autonomy-slider" id="autonomySlider"
                                   min="0" max="3" step="1" value="0" />
                            <div class="studio-bp-autonomy-label" id="autonomyLabel">Assistant</div>
                        </div>
                    </div>

                    <div class="studio-step-panel" id="stepPanel7">
                        <h2 class="studio-step-title">7. Quelles règles de sécurité ?</h2>
                        <div class="studio-check-grid cols-3" id="securityGrid"></div>
                    </div>

                    <div class="studio-step-panel" id="stepPanel8">
                        <h2 class="studio-step-title">8. Blueprint — résumé final</h2>
                        <div id="finalReview"></div>
                    </div>

                    <div class="studio-footer">
                        <div class="studio-footer-left">
                            <button type="button" class="studio-btn studio-btn-ghost" id="btnPrev" style="display:none">
                                <i class="bi bi-arrow-left"></i> Retour
                            </button>
                            <a asp-action="Index" class="studio-btn studio-btn-ghost">Annuler</a>
                        </div>
                        <div class="studio-footer-right">
                            <button type="button" class="studio-btn studio-btn-outline" id="btnDraft">
                                Enregistrer comme brouillon
                            </button>
                            <button type="button" class="studio-btn studio-btn-primary" id="btnNext">
                                Suivant <i class="bi bi-arrow-right"></i>
                            </button>
                            <button type="submit" class="studio-btn studio-btn-primary" id="btnGenerate" hidden style="display:none">
                                <i class="bi bi-stars"></i> Générer le Blueprint
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <aside class="studio-blueprint-panel">
                <div class="studio-blueprint-card">
                    <div class="studio-blueprint-head">
                        <h3><i class="bi bi-magic"></i> Blueprint en construction</h3>
                        <span class="studio-bp-status-badge">En construction</span>
                    </div>
                    <div class="studio-blueprint-body">
                        <div class="studio-bp-field">
                            <div class="studio-bp-label">Nom proposé</div>
                            <div class="studio-bp-name-row">
                                <span class="studio-bp-value" id="bp-name">Email Invoice Agent</span>
                                <button type="button" class="studio-bp-edit" id="bpEditName" title="Modifier le nom">
                                    <i class="bi bi-pencil"></i>
                                </button>
                            </div>
                        </div>
                        <div class="studio-bp-field">
                            <div class="studio-bp-label">Catégorie</div>
                            <div id="bp-category"><span class="studio-bp-pill">Email</span></div>
                        </div>
                        <div class="studio-bp-field">
                            <div class="studio-bp-label">Objectif principal</div>
                            <div class="studio-bp-value undefined" id="bp-objective">— Non défini —</div>
                        </div>
                        <div class="studio-bp-field">
                            <div class="studio-bp-label">Sources détectées</div>
                            <div class="studio-bp-value undefined" id="bp-sources">— Non défini —</div>
                        </div>
                        <div class="studio-bp-field">
                            <div class="studio-bp-label">Actions prévues</div>
                            <div class="studio-bp-value undefined" id="bp-actions">— Non défini —</div>
                        </div>
                        <div class="studio-bp-field">
                            <div class="studio-bp-label">Exécution</div>
                            <div class="studio-bp-value undefined" id="bp-trigger">— Non défini —</div>
                        </div>
                        <div class="studio-runtime-preview-card" id="runtimePreviewCard"></div>
                        <div class="studio-bp-field">
                            <div class="studio-bp-label">Niveau d'autonomie</div>
                            <div class="studio-bp-autonomy-bar">
                                <div class="studio-bp-autonomy-fill" id="bp-autonomy-fill" style="width:25%"></div>
                            </div>
                            <div class="studio-bp-autonomy-label" id="bp-autonomy">Assistant</div>
                        </div>
                        <div class="studio-bp-field">
                            <div class="studio-bp-label">Complexité estimée</div>
                            <div class="studio-bp-stars" id="bp-complexity">
                                <span>★</span><span>★</span><span>★</span><span>★</span><span>★</span>
                            </div>
                        </div>
                        <div class="studio-bp-field">
                            <div class="studio-bp-label">Coût estimé (IA)</div>
                            <div class="studio-bp-cost" id="bp-cost">$0.00 / mois</div>
                        </div>
                        <div class="studio-bp-field">
                            <div class="studio-bp-label">Runtime cible</div>
                            <div id="bp-runtime"><span class="studio-bp-pill blue">Windows Service</span></div>
                        </div>
                        <div class="studio-bp-field">
                            <div class="studio-bp-label">Statut</div>
                            <div id="bp-status"><span class="studio-bp-pill amber">En construction</span></div>
                        </div>
                    </div>
                    <div class="studio-bp-empty" id="bp-empty">
                        <div class="studio-bp-empty-icon"><i class="bi bi-diagram-3"></i></div>
                        <p>Complétez les étapes pour voir le blueprint complet de votre agent.</p>
                    </div>
                </div>
            </aside>
        </div>
    </form>

    <div class="studio-draft-toast" id="draftToast">Brouillon enregistré localement</div>
</div>

<div class="studio-modal-backdrop" id="domainModalBackdrop" role="dialog" aria-modal="true" aria-labelledby="domainModalTitle">
    <div class="studio-modal">
        <div class="studio-modal-head">
            <h3 id="domainModalTitle">Demander un nouveau domaine métier</h3>
            <p>Votre demande sera transmise à l'équipe Agentia pour validation et ajout au catalogue.</p>
        </div>
        <div id="domainModalFormWrap">
            <form id="domainRequestForm" class="studio-modal-body">
                <div class="studio-modal-field">
                    <label for="reqDomainName">Nom du domaine souhaité *</label>
                    <input type="text" id="reqDomainName" maxlength="120"
                           placeholder="Ex : Assurance, Transport maritime, Énergie…" required />
                </div>
                <div class="studio-modal-field">
                    <label for="reqIndustry">Secteur / industrie</label>
                    <input type="text" id="reqIndustry" maxlength="120"
                           placeholder="Ex : Services financiers, Agroalimentaire…" />
                </div>
                <div class="studio-modal-field">
                    <label for="reqUseCase">Cas d'usage principal</label>
                    <textarea id="reqUseCase" maxlength="2000" rows="2"
                              placeholder="Décrivez brièvement ce que l'agent devrait accomplir…"></textarea>
                </div>
                <div class="studio-modal-field">
                    <label for="reqDescription">Informations complémentaires</label>
                    <textarea id="reqDescription" maxlength="2000" rows="2"
                              placeholder="Sources de données, contraintes, intégrations souhaitées…"></textarea>
                </div>
                <div class="studio-modal-error" id="domainModalError"></div>
            </form>
            <div class="studio-modal-foot">
                <button type="button" class="studio-btn studio-btn-ghost" id="domainModalCancel">Annuler</button>
                <button type="submit" form="domainRequestForm" class="studio-btn studio-btn-primary" id="domainModalSubmit">
                    <i class="bi bi-send"></i> Envoyer la demande
                </button>
            </div>
        </div>
        <div id="domainModalSuccess" class="studio-modal-success d-none">
            <div class="studio-modal-success-icon"><i class="bi bi-check-lg"></i></div>
            <h4 style="font-size:1rem;font-weight:700;margin-bottom:8px;">Demande envoyée</h4>
            <p id="domainSuccessMsg" style="font-size:0.85rem;color:#64748b;margin-bottom:16px;"></p>
            <button type="button" class="studio-btn studio-btn-primary" id="domainModalClose">Fermer</button>
        </div>
    </div>
</div>

<div class="studio-modal-backdrop" id="objectiveModalBackdrop" role="dialog" aria-modal="true" aria-labelledby="objectiveModalTitle">
    <div class="studio-modal">
        <div class="studio-modal-head">
            <h3 id="objectiveModalTitle">Demander un nouvel objectif</h3>
            <p>Votre suggestion sera examinée par l'équipe Agentia et pourra être ajoutée au catalogue.</p>
        </div>
        <div id="objectiveModalFormWrap">
            <form id="objectiveRequestForm" class="studio-modal-body">
                <div class="studio-modal-field">
                    <label for="reqObjectiveName">Nom de l'objectif souhaité *</label>
                    <input type="text" id="reqObjectiveName" maxlength="120"
                           placeholder="Ex : Réconcilier des factures, Qualifier un appel entrant…" required />
                </div>
                <div class="studio-modal-field">
                    <label for="reqObjectiveDomain">Domaine concerné</label>
                    <input type="text" id="reqObjectiveDomain" maxlength="120"
                           placeholder="Ex : Comptabilité, Support client…" />
                </div>
                <div class="studio-modal-field">
                    <label for="reqObjectiveUseCase">Cas d'usage</label>
                    <textarea id="reqObjectiveUseCase" maxlength="2000" rows="2"
                              placeholder="Décrivez ce que l'agent devrait accomplir…"></textarea>
                </div>
                <div class="studio-modal-field">
                    <label for="reqObjectiveDescription">Informations complémentaires</label>
                    <textarea id="reqObjectiveDescription" maxlength="2000" rows="2"
                              placeholder="Entrées, sorties, contraintes, exemples…"></textarea>
                </div>
                <div class="studio-modal-error" id="objectiveModalError"></div>
            </form>
            <div class="studio-modal-foot">
                <button type="button" class="studio-btn studio-btn-ghost" id="objectiveModalCancel">Annuler</button>
                <button type="submit" form="objectiveRequestForm" class="studio-btn studio-btn-primary" id="objectiveModalSubmit">
                    <i class="bi bi-send"></i> Envoyer la demande
                </button>
            </div>
        </div>
        <div id="objectiveModalSuccess" class="studio-modal-success d-none">
            <div class="studio-modal-success-icon"><i class="bi bi-check-lg"></i></div>
            <h4 style="font-size:1rem;font-weight:700;margin-bottom:8px;">Demande envoyée</h4>
            <p id="objectiveSuccessMsg" style="font-size:0.85rem;color:#64748b;margin-bottom:16px;"></p>
            <button type="button" class="studio-btn studio-btn-primary" id="objectiveModalClose">Fermer</button>
        </div>
    </div>
</div>

<div class="studio-modal-backdrop" id="sourceConfigModalBackdrop" role="dialog" aria-modal="true" aria-labelledby="sourceConfigModalTitle">
    <div class="studio-modal studio-config-modal">
        <div class="studio-modal-head studio-config-modal-head">
            <div class="studio-config-modal-title-row">
                <span class="studio-config-modal-icon" id="sourceConfigModalIcon"><i class="bi bi-plug"></i></span>
                <div class="studio-config-modal-title-text">
                    <h3 id="sourceConfigModalTitle">Paramètres de connexion</h3>
                    <p>Les identifiants sensibles seront stockés chiffrés dans <strong>Agentia Vault</strong> — jamais en clair dans le blueprint.</p>
                </div>
                <span class="studio-config-progress" id="sourceConfigModalProgress">0/0 renseigné(s)</span>
            </div>
            <select class="studio-config-modal-selector d-none" id="sourceConfigModalSelector" aria-label="Source à configurer"></select>
        </div>
        <div class="studio-modal-body studio-config-modal-body" id="sourceConfigModalBody"></div>
        <div class="studio-modal-foot">
            <button type="button" class="studio-btn studio-btn-ghost" id="sourceConfigModalClose">Fermer</button>
            <button type="button" class="studio-btn studio-btn-primary" id="sourceConfigModalSave">
                <i class="bi bi-check-lg"></i> Enregistrer
            </button>
        </div>
    </div>
</div>

<div class="studio-modal-backdrop" id="actionConfigModalBackdrop" role="dialog" aria-modal="true" aria-labelledby="actionConfigModalTitle">
    <div class="studio-modal studio-config-modal">
        <div class="studio-modal-head studio-config-modal-head">
            <div class="studio-config-modal-title-row">
                <span class="studio-config-modal-icon" id="actionConfigModalIcon"><i class="bi bi-gear"></i></span>
                <div class="studio-config-modal-title-text">
                    <h3 id="actionConfigModalTitle">Paramètres de l'action</h3>
                    <p>Configurez cette action. Les secrets seront stockés chiffrés dans <strong>Agentia Vault</strong>.</p>
                </div>
                <span class="studio-config-progress" id="actionConfigModalProgress">0/0 renseigné(s)</span>
            </div>
            <select class="studio-config-modal-selector d-none" id="actionConfigModalSelector" aria-label="Action à configurer"></select>
        </div>
        <div class="studio-modal-body studio-config-modal-body" id="actionConfigModalBody"></div>
        <div class="studio-modal-foot">
            <button type="button" class="studio-btn studio-btn-ghost" id="actionConfigModalClose">Fermer</button>
            <button type="button" class="studio-btn studio-btn-primary" id="actionConfigModalSave">
                <i class="bi bi-check-lg"></i> Enregistrer
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        window.STUDIO_DOMAINS = @Html.Raw(JsonSerializer.Serialize(studioDomains.Select(d => new {
            id = d.Id, icon = d.Icon, bg = d.Bg, color = d.Color,
            name = d.Name, desc = d.Desc, namePrefix = d.NamePrefix, defaultAgent = d.DefaultAgent
        })));
    </script>
    <script src="~/js/agentia-studio-sources.js" asp-append-version="true"></script>
    <script src="~/js/agentia-studio-actions.js" asp-append-version="true"></script>
    <script src="~/js/agentia-studio-runtime.js" asp-append-version="true"></script>
    <script src="~/js/agentia-studio.js" asp-append-version="true"></script>
}
