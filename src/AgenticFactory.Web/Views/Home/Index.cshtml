@model AgenticFactory.Web.Models.LoginViewModel
@{
    Layout = "_LandingLayout";
    ViewData["Title"] = "Accueil";
}

<div class="landing-topbar">
    <div></div>
    <div class="landing-topbar-actions">
        <button type="button" class="landing-theme-btn" aria-label="Thème"><i class="bi bi-sun"></i></button>
        <a asp-controller="Account" asp-action="Register" class="landing-btn-outline">Créer un compte</a>
    </div>
</div>

<section class="landing-hero">
    <div class="landing-hero-copy">
        <img src="~/images/agencia-os-logo-gold.png" alt="Agencia OS" class="landing-hero-logo" asp-append-version="true" />
        <span class="landing-badge">✦ Plateforme Agentic AI</span>
        <h1 class="landing-hero-title">Construisez des agents IA <em>sans coder.</em></h1>
        <p class="landing-hero-sub">Créez, entraînez, déployez et monétisez vos agents intelligents sur une seule plateforme.</p>

        <ul class="landing-features">
            <li>
                <span class="landing-feat-icon purple"><i class="bi bi-grid-1x2-fill"></i></span>
                <div class="landing-feat-text">
                    <strong>Création No-Code</strong>
                    <span>Interface visuelle intuitive, aucun développement requis</span>
                </div>
            </li>
            <li>
                <span class="landing-feat-icon green"><i class="bi bi-diagram-3-fill"></i></span>
                <div class="landing-feat-text">
                    <strong>Orchestration Multi-Agents</strong>
                    <span>Composez des workflows IA complexes</span>
                </div>
            </li>
            <li>
                <span class="landing-feat-icon amber"><i class="bi bi-bag-fill"></i></span>
                <div class="landing-feat-text">
                    <strong>Marketplace d'agents</strong>
                    <span>Publiez et partagez vos agents avec la communauté</span>
                </div>
            </li>
            <li>
                <span class="landing-feat-icon blue"><i class="bi bi-rocket-takeoff-fill"></i></span>
                <div class="landing-feat-text">
                    <strong>Déploiement Instantané</strong>
                    <span>De l'idée à la production en quelques minutes</span>
                </div>
            </li>
        </ul>

        <div class="landing-hero-actions">
            <a href="#connexion" class="landing-btn-primary">Explorer la plateforme →</a>
            <a href="#" class="landing-btn-secondary">Voir la marketplace</a>
        </div>
    </div>

    <div class="landing-hero-visual">
        <div class="landing-visual-glow" aria-hidden="true"></div>

        <svg class="landing-orbit-lines" aria-hidden="true" viewBox="0 0 420 420">
            <path d="M60 80 Q180 120 210 200" stroke="#c7d2fe" stroke-width="1.5" fill="none" stroke-dasharray="4 6"/>
            <path d="M360 60 Q280 140 240 190" stroke="#c7d2fe" stroke-width="1.5" fill="none" stroke-dasharray="4 6"/>
            <path d="M380 280 Q300 240 260 220" stroke="#c7d2fe" stroke-width="1.5" fill="none" stroke-dasharray="4 6"/>
            <path d="M40 300 Q120 260 190 230" stroke="#c7d2fe" stroke-width="1.5" fill="none" stroke-dasharray="4 6"/>
            <path d="M100 360 Q160 300 200 260" stroke="#c7d2fe" stroke-width="1.5" fill="none" stroke-dasharray="4 6"/>
        </svg>

        <div class="landing-dashboard-mock" aria-hidden="true">
            <div class="landing-mock-header"><span></span><span></span><span></span></div>
            <div class="landing-mock-toolbar">
                <span class="landing-mock-dot active"></span>
                <span class="landing-mock-line"></span>
                <span class="landing-mock-line short"></span>
            </div>
            <div class="landing-mock-chart"></div>
            <div class="landing-mock-flow">
                <div class="landing-mock-node n1">Input</div>
                <div class="landing-mock-node n2 core">Agent IA</div>
                <div class="landing-mock-node n3">Output</div>
            </div>
        </div>

        <span class="landing-orbit o1" aria-hidden="true"><i class="bi bi-robot"></i></span>
        <span class="landing-orbit o2" aria-hidden="true"><i class="bi bi-cloud"></i></span>
        <span class="landing-orbit o3" aria-hidden="true"><i class="bi bi-envelope"></i></span>
        <span class="landing-orbit o4" aria-hidden="true"><i class="bi bi-database"></i></span>
        <span class="landing-orbit o5" aria-hidden="true"><i class="bi bi-graph-up-arrow"></i></span>

        <div class="landing-login-card" id="connexion">
            <h2>Connexion</h2>
            <p class="subtitle">Accédez à votre espace architecte</p>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="landing-alert">
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <div>@error.ErrorMessage</div>
                    }
                </div>
            }

            <form asp-controller="Account" asp-action="Login" method="post" class="landing-form">
                @Html.AntiForgeryToken()
                <label>
                    Email
                    <input asp-for="Email" type="email" placeholder="admin@agenticfactory.local" autocomplete="email" />
                </label>
                <label>
                    Mot de passe
                    <span class="auth-password-input">
                        <input asp-for="Password" type="password" placeholder="••••••••" autocomplete="current-password" />
                        <button type="button" class="auth-password-toggle" aria-label="Afficher le mot de passe">
                            <i class="bi bi-eye"></i>
                        </button>
                    </span>
                </label>
                <div class="landing-form-row">
                    <label><input type="checkbox" name="remember" /> Se souvenir de moi</label>
                    <a href="#" class="landing-forgot">Mot de passe oublié ?</a>
                </div>
                <button type="submit" class="landing-btn-primary">Se connecter →</button>
            </form>
            <p class="landing-form-footer">Pas encore de compte ? <a asp-controller="Account" asp-action="Register">Créer un compte</a></p>
        </div>
    </div>
</section>

<section class="landing-stats">
    <article class="landing-stat">
        <span class="landing-stat-icon purple"><i class="bi bi-robot"></i></span>
        <div>
            <div class="landing-stat-value">Studio visuel</div>
            <div class="landing-stat-label">Wizard 8 étapes</div>
            <div class="landing-stat-delta neutral">Création guidée d'agents IA</div>
        </div>
    </article>
    <article class="landing-stat">
        <span class="landing-stat-icon green"><i class="bi bi-lightning-charge-fill"></i></span>
        <div>
            <div class="landing-stat-value">Déploiement</div>
            <div class="landing-stat-label">Pipeline multi-env.</div>
            <div class="landing-stat-delta neutral">Dev, staging, production</div>
        </div>
    </article>
    <article class="landing-stat">
        <span class="landing-stat-icon amber"><i class="bi bi-activity"></i></span>
        <div>
            <div class="landing-stat-value">Monitoring</div>
            <div class="landing-stat-label">Runs &amp; coûts réels</div>
            <div class="landing-stat-delta neutral">Données de votre organisation</div>
        </div>
    </article>
    <article class="landing-stat">
        <span class="landing-stat-icon blue"><i class="bi bi-shield-check"></i></span>
        <div>
            <div class="landing-stat-value">Multi-tenant</div>
            <div class="landing-stat-label">Isolation par org.</div>
            <div class="landing-stat-delta neutral">Sécurité et audit intégrés</div>
        </div>
    </article>
</section>

<section class="landing-partners">
    <p>Utilisé par des équipes innovantes dans le monde entier</p>
    <div class="landing-partner-logos">
        <span>TechNova</span>
        <span>DataSync</span>
        <span>CloudFlow</span>
        <span>InnovateAI</span>
        <span>FutureCorp</span>
        <span>ByteWorks</span>
    </div>
</section>
