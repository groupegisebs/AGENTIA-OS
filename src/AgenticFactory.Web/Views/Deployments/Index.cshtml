@model AgenticFactory.Web.Models.DeploymentsIndexViewModel
@{
    ViewData["Title"] = "Déploiements";
}

<div class="mb-4">
    <h2 class="mb-1">Déploiements</h2>
    <p class="text-muted mb-0">Versions actives et historique des déploiements.</p>
</div>

@if (!Model.Deployments.Any())
{
    <div class="af-card text-center py-5">
        <i class="bi bi-lightning display-4 text-muted"></i>
        <p class="mt-3 mb-3 text-muted">Aucun déploiement. Créez et déployez un agent depuis la section Agents.</p>
        <a asp-controller="Agents" asp-action="Index" class="btn btn-primary">Aller aux agents</a>
    </div>
}
else
{
    <div class="table-responsive af-card p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Agent</th>
                    <th>Version</th>
                    <th>Environnement</th>
                    <th>Statut</th>
                    <th>Activé le</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var d in Model.Deployments)
            {
                var isActive = d.Status.Equals("Active", StringComparison.OrdinalIgnoreCase);
                <tr>
                    <td>
                        <strong>@d.AgentName</strong>
                        <div class="small"><code>@d.EndpointSlug</code></div>
                    </td>
                    <td>v@d.VersionNumber</td>
                    <td>@d.Environment</td>
                    <td><span class="badge @(isActive ? "text-bg-success" : "text-bg-secondary")">@d.Status</span></td>
                    <td>@(d.ActivatedAtUtc?.ToLocalTime().ToString("g") ?? "—")</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}
