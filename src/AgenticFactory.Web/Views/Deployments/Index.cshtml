@model AgenticFactory.Web.Models.DeploymentsIndexViewModel
@{
    ViewData["Title"] = "Déploiements";
}

<div class="deploy-page">
    <nav class="deploy-breadcrumb">
        <a asp-controller="Dashboard" asp-action="Index">Accueil</a>
        <span class="sep">›</span>
        <span>Déploiements</span>
    </nav>

    <div class="deploy-head">
        <div>
            <h1>Déploiements</h1>
            <p class="text-muted mb-0 mt-1">Pipeline, versions et environnements de vos agents.</p>
        </div>
        <div class="deploy-head-actions">
            @await Component.InvokeAsync("PlatformStatus")
            <a asp-controller="Agents" asp-action="Create" class="deploy-btn-primary">
                <i class="bi bi-plus-lg"></i> Nouveau déploiement
            </a>
        </div>
    </div>

    @if (Model.PublishEligibility is { CanPublish: false } pub)
    {
        <div class="deploy-alert alert alert-info">
            <i class="bi bi-info-circle me-1"></i> @pub.Message
            <a asp-controller="Agents" asp-action="Index" class="ms-2">Voir les options de paiement</a>
        </div>
    }

    @if (!Model.AgentGroups.Any())
    {
        <div class="deploy-panel text-center py-5">
            <i class="bi bi-lightning display-4 text-muted opacity-50"></i>
            <p class="mt-3 mb-3 text-muted">Aucun déploiement. Créez et déployez un agent d'abord.</p>
            <a asp-controller="Agents" asp-action="Index" class="deploy-btn-primary">Aller aux agents</a>
        </div>
    }
    else
    {
        <div class="deploy-agent-cards">
            @foreach (var g in Model.AgentGroups)
            {
                <a asp-action="Detail" asp-route-id="@g.AgentId" class="deploy-agent-card">
                    <h3>@g.AgentName</h3>
                    <div class="slug mb-2">@g.EndpointSlug</div>
                    <div class="d-flex flex-wrap gap-2 mb-2">
                        <span class="deploy-badge deployed">@g.Status</span>
                        <span class="deploy-version-tag">@g.CurrentVersion</span>
                        <span class="deploy-badge ready">@g.Environment</span>
                    </div>
                    <div class="small text-muted">
                        @g.DeploymentCount déploiement(s) · Dernier : @(g.LastDeployedAt?.ToLocalTime().ToString("g") ?? "—")
                    </div>
                </a>
            }
        </div>
    }
</div>
