@model AgenticFactory.Web.Models.DeploymentDetailViewModel
@{
    ViewData["Title"] = "Déploiement";
    var prod = Model.Production;
    string TriggerIcon(string type) => type switch
    {
        "Scheduled" => "bi-calendar-event",
        "Webhook" => "bi-link-45deg",
        _ => "bi-clock"
    };
    string FormatUptime(int days, int hours)
    {
        var h = hours % 24;
        return days > 0 ? $"{days} jour{(days > 1 ? "s" : "")}, {h} heure{(h > 1 ? "s" : "")}" : $"{hours} heure{(hours > 1 ? "s" : "")}";
    }
    string DeploymentStatusLabel(string status) => status switch
    {
        "Active" => "Actif",
        "Failed" => "Échec",
        "Pending" => "En attente",
        _ => status
    };
    string RuntimeStatusLabel(string status) => status switch
    {
        "Healthy" => "Sain",
        "Degraded" => "Dégradé",
        "Unknown" => "Inconnu",
        _ => status
    };
}

<div class="deploy-page">
    <nav class="deploy-breadcrumb">
        <a asp-controller="Dashboard" asp-action="Index">Accueil</a>
        <span class="sep">›</span>
        <a asp-controller="Agents" asp-action="Index">Agents</a>
        <span class="sep">›</span>
        <span>@Model.AgentName</span>
        <span class="sep">›</span>
        <span>Déploiements</span>
    </nav>

    @if (TempData["Success"] is string success)
    {
        <div class="deploy-alert alert alert-success">@success</div>
    }
    @if (TempData["Error"] is string error)
    {
        <div class="deploy-alert alert alert-danger">@error</div>
    }
    @if (TempData["ApiKey"] is string apiKey)
    {
        <div class="deploy-alert alert alert-warning">
            <strong>Clé API :</strong> <code class="user-select-all">@apiKey</code>
        </div>
    }

    <div class="deploy-head">
        <div>
            <h1>
                Déploiement
                <span class="deploy-version-tag">@Model.VersionLabel</span>
            </h1>
            <p class="text-muted mb-0 mt-1">@Model.AgentName — @Model.Description</p>
        </div>
        <div class="deploy-head-actions">
            @await Component.InvokeAsync("PlatformStatus")
            @if (Model.LatestBlueprintId.HasValue)
            {
                <form asp-action="Redeploy" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="agentId" value="@Model.AgentId" />
                    <input type="hidden" name="blueprintId" value="@Model.LatestBlueprintId" />
                    <button type="submit" class="deploy-btn-primary border-0">
                        <i class="bi bi-plus-lg"></i> Nouveau déploiement
                    </button>
                </form>
            }
            else
            {
                <a asp-controller="Agents" asp-action="Create" class="deploy-btn-primary">
                    <i class="bi bi-plus-lg"></i> Nouveau déploiement
                </a>
            }
        </div>
    </div>

    <div class="deploy-grid">
        <div class="deploy-main">
            <!-- Pipeline -->
            <div class="deploy-panel">
                <div class="deploy-panel-head">
                    <h2 class="deploy-panel-title">Pipeline de déploiement</h2>
                    <button type="button" class="deploy-btn-outline btn-sm" disabled title="Bientôt disponible">Configurer le pipeline</button>
                </div>
                <div class="deploy-pipeline">
                    @foreach (var step in Model.Pipeline)
                    {
                        var isActive = step.Status.Equals("Active", StringComparison.OrdinalIgnoreCase);
                        <div class="deploy-pipe-step @(isActive ? "active" : "")">
                            <div class="deploy-pipe-label">@step.Label</div>
                            <div class="deploy-pipe-name">@(step.VersionLabel ?? "—")</div>
                            <div class="deploy-pipe-status @(isActive ? "ok" : "off")">@(isActive ? "Actif" : "Inactif")</div>
                            <div class="deploy-pipe-meta">
                                @(step.DeployedAt?.ToLocalTime().ToString("d MMM yyyy") ?? "Non déployé")
                            </div>
                        </div>
                    }
                    <div class="deploy-pipe-step">
                        <div class="deploy-pipe-label">Prochain</div>
                        <div class="deploy-pipe-name">—</div>
                        <div class="deploy-pipe-status off">Aucun planifié</div>
                    </div>
                </div>
            </div>

            <!-- Versions -->
            <div class="deploy-panel">
                <h2 class="deploy-panel-title mb-3">Versions disponibles</h2>
                @if (!Model.Versions.Any())
                {
                    <p class="text-muted mb-0">Aucune version.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="deploy-table">
                            <thead>
                                <tr>
                                    <th>Version</th>
                                    <th>Description</th>
                                    <th>Créée le</th>
                                    <th>Créée par</th>
                                    <th>Statut</th>
                                </tr>
                            </thead>
                            <tbody>
                            @foreach (var v in Model.Versions)
                            {
                                <tr>
                                    <td>
                                        <strong>@v.Label</strong>
                                        @if (v.IsCurrent) { <span class="deploy-badge current">Actuelle</span> }
                                    </td>
                                    <td class="text-muted small">@v.Description</td>
                                    <td>@v.CreatedAt.ToLocalTime().ToString("d MMM yyyy")</td>
                                    <td>@v.CreatedBy</td>
                                    <td>
                                        <span class="deploy-badge @(v.Status == "Déployée" ? "deployed" : "ready")">@v.Status</span>
                                    </td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                }
            </div>

            <!-- Production -->
            @if (prod is not null)
            {
                <div class="deploy-panel">
                    <h2 class="deploy-panel-title mb-3">Détails du déploiement (@Capitalize(prod.Environment))</h2>
                    <div class="deploy-prod-grid">
                        <div>
                            <div class="deploy-field-label">Statut</div>
                            <div class="deploy-field-value"><span class="deploy-badge deployed">@DeploymentStatusLabel(prod.Status)</span></div>
                        </div>
                        <div>
                            <div class="deploy-field-label">URL de l'agent</div>
                            <div class="deploy-field-value mono">@Model.InvokeUrl</div>
                        </div>
                        <div>
                            <div class="deploy-field-label">Clé API</div>
                            <div class="deploy-field-value mono">@prod.ApiKeyMasked</div>
                        </div>
                        <div>
                            <div class="deploy-field-label">Nœud d'exécution</div>
                            <div class="deploy-field-value">
                                @prod.RuntimeNode
                                <span class="deploy-badge deployed ms-1">@RuntimeStatusLabel(prod.RuntimeStatus)</span>
                            </div>
                        </div>
                        <div>
                            <div class="deploy-field-label">Uptime</div>
                            <div class="deploy-field-value">@FormatUptime(prod.UptimeDays, prod.UptimeHours)</div>
                        </div>
                        <div>
                            <div class="deploy-field-label">Triggers actifs</div>
                            <div class="deploy-triggers">
                                @if (!prod.TriggerTypes.Any())
                                {
                                    <span class="text-muted small">Aucun</span>
                                }
                                @foreach (var t in prod.TriggerTypes)
                                {
                                    <span class="deploy-trigger-icon" title="@t"><i class="bi @TriggerIcon(t)"></i></span>
                                }
                            </div>
                        </div>
                    </div>
                    <div class="deploy-actions-row">
                        @if (Model.LatestBlueprintId.HasValue)
                        {
                            <form asp-action="Redeploy" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="agentId" value="@Model.AgentId" />
                                <input type="hidden" name="blueprintId" value="@Model.LatestBlueprintId" />
                                <button type="submit" class="deploy-btn-primary border-0">Redéployer</button>
                            </form>
                        }
                        <button type="button" class="deploy-btn-outline" disabled title="Bientôt disponible">Rollback</button>
                        <button type="button" class="deploy-btn-outline" disabled title="Bientôt disponible">Suspendre</button>
                        <button type="button" class="deploy-btn-outline deploy-btn-danger" disabled title="Bientôt disponible">Supprimer</button>
                    </div>
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(Model.EndpointSlug))
            {
                <div class="deploy-panel" id="test-invoke-panel">
                    <h2 class="deploy-panel-title mb-2">Tester l'invoke</h2>
                    <p class="deploy-invoke-help text-muted small mb-3">
                        Envoyez une requête de test à <code class="user-select-all">@Model.InvokeUrl</code>.
                        La clé API n'est affichée qu'une seule fois lors du déploiement — collez-la ci-dessous si vous ne l'avez plus enregistrée.
                    </p>

                    <form asp-action="TestInvoke" method="post" class="deploy-invoke-form">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.AgentId" />

                        <div class="deploy-invoke-field">
                            <label class="deploy-field-label" for="invokeApiKey">Clé API</label>
                            <input type="password"
                                   class="deploy-invoke-input"
                                   id="invokeApiKey"
                                   name="testInvoke.ApiKey"
                                   autocomplete="off"
                                   placeholder="Collez votre clé API agent" />
                        </div>

                        <div class="deploy-invoke-field">
                            <label class="deploy-field-label" for="invokeInputJson">Entrée JSON</label>
                            <textarea class="deploy-invoke-textarea"
                                      id="invokeInputJson"
                                      name="testInvoke.InputJson"
                                      rows="5"
                                      spellcheck="false">@Model.TestInvoke.InputJson</textarea>
                            <div class="deploy-invoke-hint">Objet JSON passé dans le champ <code>input</code> de l'invoke.</div>
                        </div>

                        <div class="deploy-actions-row mt-0 pt-0 border-0">
                            <button type="submit" class="deploy-btn-primary border-0">
                                <i class="bi bi-play-fill"></i> Tester l'invoke
                            </button>
                        </div>
                    </form>

                    @if (Model.InvokeResult is not null)
                    {
                        var r = Model.InvokeResult;
                        <div class="deploy-invoke-result @(r.Success ? "ok" : "err")">
                            <div class="deploy-invoke-result-head">
                                <strong>@(r.Success ? "Invoke réussi" : "Échec de l'invoke")</strong>
                                @if (r.HttpStatus is int code)
                                {
                                    <span class="deploy-invoke-http">HTTP @code</span>
                                }
                            </div>

                            @if (!r.Success)
                            {
                                <p class="deploy-invoke-error mb-0">@r.ErrorMessage</p>
                            }
                            else
                            {
                                <div class="deploy-invoke-metrics">
                                    @if (r.RunId is Guid runId)
                                    {
                                        <div><span class="label">Run ID</span><span class="value mono user-select-all">@runId</span></div>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(r.Status))
                                    {
                                        <div><span class="label">Statut</span><span class="value">@r.Status</span></div>
                                    }
                                    @if (r.PromptTokens is int pt)
                                    {
                                        <div><span class="label">Tokens (prompt)</span><span class="value">@pt.ToString("N0")</span></div>
                                    }
                                    @if (r.CompletionTokens is int ct)
                                    {
                                        <div><span class="label">Tokens (complétion)</span><span class="value">@ct.ToString("N0")</span></div>
                                    }
                                    @if (r.EstimatedCostUsd is decimal cost)
                                    {
                                        <div><span class="label">Coût estimé</span><span class="value">$@cost.ToString("0.0000")</span></div>
                                    }
                                </div>

                                @if (!string.IsNullOrWhiteSpace(r.OutputJson))
                                {
                                    <div class="deploy-invoke-output-wrap">
                                        <div class="deploy-invoke-output-head">
                                            <span class="deploy-field-label mb-0">Sortie</span>
                                            <button type="button" class="deploy-btn-outline btn-sm" id="copyInvokeOutput" title="Copier le JSON">
                                                <i class="bi bi-clipboard"></i> Copier
                                            </button>
                                        </div>
                                        <pre class="deploy-invoke-output" id="invokeOutputPre">@r.OutputJson</pre>
                                    </div>
                                }
                            }
                        </div>
                    }
                </div>
            }

            <!-- Logs -->
            <div class="deploy-panel">
                <h2 class="deploy-panel-title mb-3">Journal des opérations</h2>
                @if (!Model.OperationLogs.Any())
                {
                    <p class="text-muted mb-0">Aucune opération enregistrée.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="deploy-table">
                            <thead>
                                <tr><th>Date</th><th>Niveau</th><th>Message</th></tr>
                            </thead>
                            <tbody>
                            @foreach (var log in Model.OperationLogs)
                            {
                                var lvl = log.Level.ToLowerInvariant();
                                <tr>
                                    <td class="text-nowrap">@log.At.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss")</td>
                                    <td><span class="deploy-log-level @lvl">@log.Level</span></td>
                                    <td>@log.Message</td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

        <div class="deploy-side">
            <div class="deploy-panel">
                <h2 class="deploy-panel-title mb-3">Déploiements récents</h2>
                @if (!Model.RecentTimeline.Any())
                {
                    <p class="text-muted small mb-0">Aucun historique.</p>
                }
                else
                {
                    <ul class="deploy-timeline">
                        @foreach (var t in Model.RecentTimeline)
                        {
                            var cls = t.Outcome.Contains("chec") ? "fail" : t.Outcome.Contains("Succ") ? "ok" : "";
                            <li class="@cls">
                                <div class="deploy-tl-title">@t.Environment @t.VersionLabel</div>
                                <div class="deploy-tl-meta">@t.At.ToLocalTime().ToString("g") · @t.Outcome</div>
                            </li>
                        }
                    </ul>
                }
            </div>

            <div class="deploy-panel">
                <h2 class="deploy-panel-title mb-3">Utilisation (Production)</h2>
                <p class="small text-muted mb-3">30 derniers jours</p>
                <div class="deploy-usage-stat">
                    <div class="label">Exécutions</div>
                    <div class="value">@Model.Usage.Runs.ToString("N0")</div>
                </div>
                <div class="deploy-usage-stat">
                    <div class="label">Tokens consommés</div>
                    <div class="value">@(Model.Usage.Tokens >= 1_000_000 ? $"{Model.Usage.Tokens / 1_000_000.0:0.##}M" : Model.Usage.Tokens.ToString("N0"))</div>
                </div>
                <div class="deploy-usage-stat">
                    <div class="label">Coût total</div>
                    <div class="value">$@Model.Usage.Cost.ToString("0.00")</div>
                </div>
                <div class="deploy-usage-stat">
                    <div class="label">Erreurs</div>
                    <div class="value">@Model.Usage.Errors</div>
                </div>
                <div class="deploy-chart-sm">
                    <canvas id="deployUsageChart"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

@functions {
    string Capitalize(string s) =>
        string.IsNullOrEmpty(s) ? s : char.ToUpper(s[0]) + s[1..].ToLowerInvariant();
}

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
<script>
(() => {
    const data = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Usage.TokenSeries));
    const el = document.getElementById('deployUsageChart');
    if (!el) return;
    new Chart(el, {
        type: 'line',
        data: {
            labels: data.map(() => ''),
            datasets: [{
                data,
                borderColor: '#6366f1',
                backgroundColor: 'rgba(99,102,241,.15)',
                fill: true,
                tension: 0.35,
                pointRadius: 0,
                borderWidth: 2
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: { x: { display: false }, y: { display: false, beginAtZero: true } }
        }
    });
})();

(() => {
    const copyBtn = document.getElementById('copyInvokeOutput');
    const pre = document.getElementById('invokeOutputPre');
    if (!copyBtn || !pre) return;
    copyBtn.addEventListener('click', async () => {
        try {
            await navigator.clipboard.writeText(pre.textContent || '');
            copyBtn.innerHTML = '<i class="bi bi-check2"></i> Copié';
            setTimeout(() => { copyBtn.innerHTML = '<i class="bi bi-clipboard"></i> Copier'; }, 2000);
        } catch {
            copyBtn.title = 'Copie impossible dans ce navigateur';
        }
    });
})();

(() => {
    const panel = document.getElementById('test-invoke-panel');
    @if (Model.InvokeResult is not null)
    {
        <text>if (panel) panel.scrollIntoView({ behavior: 'smooth', block: 'start' });</text>
    }
})();
</script>
}
