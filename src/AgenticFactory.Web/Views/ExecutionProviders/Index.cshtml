@model AgenticFactory.Web.Models.ExecutionProvidersIndexViewModel
@{
    ViewData["Title"] = "Execution Providers";
}

<div class="mb-4">
    <h2 class="mb-1">Execution Providers</h2>
    <p class="text-muted mb-0">Catalogue des moteurs d'exécution pour les actions de vos agents — Runtime Windows, Power Automate, Logic Apps, n8n, etc.</p>
</div>

@if (!Model.Providers.Any())
{
    <div class="af-card">
        <p class="text-muted mb-0">Aucun provider configuré. Vérifiez que l'API est accessible et que les migrations ont été appliquées.</p>
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var p in Model.Providers)
        {
            <div class="col-md-6 col-xl-4">
                <div class="af-card h-100">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <div>
                            <div class="text-muted small text-uppercase fw-semibold">@p.Category</div>
                            <h5 class="mb-1">@p.Name</h5>
                        </div>
                        <span class="badge @(p.IsEnabled ? "bg-success-subtle text-success" : "bg-secondary-subtle text-secondary")">@p.State</span>
                    </div>
                    <p class="text-muted small mb-3">@p.Description</p>
                    <div class="small text-muted mb-2">
                        <span class="me-3"><i class="bi bi-tag"></i> @p.ProviderType</span>
                        <span class="me-3"><i class="bi bi-box"></i> v@p.Version</span>
                        <span><i class="bi bi-person"></i> @p.Author</span>
                    </div>
                    <div class="d-flex flex-wrap gap-1 mb-3">
                        @if (p.SupportsMonitoring) { <span class="badge bg-light text-dark border">Monitoring</span> }
                        @if (p.SupportsRetry) { <span class="badge bg-light text-dark border">Retry</span> }
                        @if (p.SupportsRollback) { <span class="badge bg-light text-dark border">Rollback</span> }
                        @if (p.SupportsScheduling) { <span class="badge bg-light text-dark border">Planification</span> }
                        @if (p.SupportsParameters) { <span class="badge bg-light text-dark border">Paramètres</span> }
                    </div>
                    <button type="button" class="btn btn-sm btn-outline-primary" disabled title="Configuration avancée — Phase 2">
                        <i class="bi bi-gear"></i> Configurer
                    </button>
                </div>
            </div>
        }
    </div>
}

<div class="af-card mt-4">
    <h5 class="mb-2"><i class="bi bi-info-circle"></i> Comment ça fonctionne ?</h5>
    <p class="text-muted mb-2">Le <strong>Windows Service</strong> reste l'orchestrateur principal de votre agent. Chaque action (actionneur) peut être exécutée par le provider de votre choix.</p>
    <p class="text-muted mb-0">Lors de la création d'un agent dans le Studio, sélectionnez le provider pour chaque actionneur à l'étape <strong>Act</strong>.</p>
</div>
