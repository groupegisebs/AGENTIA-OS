@{
    ViewData["Title"] = ViewData["FeatureName"]?.ToString() ?? "Bientôt disponible";
}

<div class="af-card text-center py-5" style="max-width: 520px; margin: 0 auto;">
    <i class="bi bi-cone-striped display-4 text-muted"></i>
    <h2 class="mt-3">@ViewData["FeatureName"]</h2>
    <p class="text-muted">Cette section sera disponible dans une prochaine version.</p>
    <a asp-controller="Dashboard" asp-action="Index" class="btn btn-primary mt-2">
        <i class="bi bi-grid-1x2 me-1"></i> Retour au dashboard
    </a>
</div>
