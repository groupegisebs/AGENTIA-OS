<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Agentia</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Fraunces:opsz,wght@9..144,500;9..144,600;9..144,700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/agentia-auth.css" asp-append-version="true" />
</head>
<body class="auth-guest">
<div id="app">
    <header class="topbar">
        <a asp-controller="Account" asp-action="Login" class="brand">
            <span class="brand-mark">A</span>
            <span>Agentia</span>
        </a>
        <div class="topnav-actions">
            @if (ViewContext.RouteData.Values["action"]?.ToString() == "Login")
            {
                <a asp-action="Register" class="nav-link-login">Créer un compte</a>
            }
            else
            {
                <a asp-action="Login" class="nav-link-login">Connexion</a>
            }
        </div>
    </header>

    <main class="auth-premium">
        <div class="auth-premium-bg" aria-hidden="true">
            <div class="auth-gradient"></div>
            <div class="auth-nebula"></div>
            <div class="auth-grid-lines"></div>
            <div class="auth-particles">
                @for (var i = 0; i < 32; i++)
                {
                    <span style="--i:@i"></span>
                }
            </div>
        </div>

        <div class="auth-premium-grid">
            <partial name="_AuthPremiumLeft" />
            <div class="auth-premium-right">
                <div class="auth-card">
                    <div class="auth-card-glow" aria-hidden="true"></div>
                    <div class="auth-card-header">
                        <h2>@ViewData["CardTitle"]</h2>
                        @if (ViewData["CardSubtitle"] is string subtitle)
                        {
                            <p>@subtitle</p>
                        }
                    </div>
                    @RenderBody()
                </div>
            </div>
        </div>

        <partial name="_AuthTrustBar" />
    </main>
</div>
<script src="~/js/agentia-auth.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
