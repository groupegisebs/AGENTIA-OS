@{
    var activeNav = ViewData["ActiveNav"]?.ToString() ?? "";
    var dashMode = ViewData["DashboardMode"] as bool? == true;
}
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Agentia</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/agentia-dashboard.css" asp-append-version="true" />
    <style>
        :root {
            --af-primary: #6366f1;
            --af-sidebar-bg: #0f172a;
            --af-sidebar-text: #94a3b8;
        }
        * { font-family: 'Inter', sans-serif; }
        body { background: #f8fafc; min-height: 100vh; }
        .af-sidebar {
            width: 260px; min-height: 100vh; background: var(--af-sidebar-bg);
            position: fixed; top: 0; left: 0; z-index: 100;
            display: flex; flex-direction: column;
        }
        .af-sidebar-brand {
            padding: 20px 24px; border-bottom: 1px solid #1e293b;
            color: #fff; font-weight: 700; font-size: 1.1rem;
            display: flex; align-items: center; gap: 10px;
        }
        .af-sidebar-brand .brand-icon {
            width: 32px; height: 32px; background: var(--af-primary);
            border-radius: 8px; display: flex; align-items: center;
            justify-content: center; color: white; font-size: 0.9rem; font-weight: 700;
        }
        .af-nav-item a {
            display: flex; align-items: center; gap: 12px;
            padding: 10px 24px; color: var(--af-sidebar-text);
            text-decoration: none; font-size: 0.875rem; font-weight: 500;
            border-left: 3px solid transparent; transition: all 0.15s;
        }
        .af-nav-item a:hover, .af-nav-item a.active {
            color: #fff; background: rgba(99,102,241,.12);
            border-left-color: var(--af-primary);
        }
        .af-nav-section {
            padding: 16px 24px 6px; font-size: 0.7rem; font-weight: 600;
            color: #475569; text-transform: uppercase; letter-spacing: .08em;
        }
        .af-sidebar-footer { padding: 12px 16px 16px; border-top: 1px solid #1e293b; }
        .af-main { margin-left: 260px; min-height: 100vh; }
        .af-topbar {
            background: #fff; border-bottom: 1px solid #e2e8f0;
            padding: 0 32px; height: 60px; display: flex;
            align-items: center; justify-content: space-between;
            position: sticky; top: 0; z-index: 50;
        }
        .af-topbar-title { font-weight: 600; font-size: 1rem; color: #0f172a; }
        .af-content { padding: 32px; }
        .af-card {
            background: #fff; border: 1px solid #e2e8f0; border-radius: 12px;
            padding: 24px; box-shadow: 0 1px 3px rgba(0,0,0,.05);
        }
        .af-stat-value { font-size: 2rem; font-weight: 700; color: #0f172a; }
    </style>
</head>
<body class="@(dashMode ? "dash-mode" : "")">
    <aside class="af-sidebar">
        <div class="af-sidebar-brand">
            <div class="brand-icon">A</div>
            Agentia
        </div>
        <nav class="af-nav">
            <div class="af-nav-section">Principal</div>
            <div class="af-nav-item">
                <a asp-controller="Dashboard" asp-action="Index" class="@(activeNav == "Dashboard" ? "active" : "")">
                    <i class="bi bi-grid-1x2"></i> Dashboard
                </a>
            </div>

            <div class="af-nav-section">Plateforme</div>
            <div class="af-nav-item">
                <a asp-controller="Agents" asp-action="Index" class="@(activeNav == "Agents" ? "active" : "")">
                    <i class="bi bi-robot"></i> Agents
                </a>
            </div>
            <div class="af-nav-item">
                <a asp-controller="Deployments" asp-action="Index" class="@(activeNav == "Deployments" ? "active" : "")">
                    <i class="bi bi-lightning"></i> Déploiements
                </a>
            </div>
            <div class="af-nav-item">
                <a asp-controller="Executions" asp-action="Index" class="@(activeNav == "Executions" ? "active" : "")">
                    <i class="bi bi-activity"></i> Exécutions
                </a>
            </div>
            <div class="af-nav-item">
                <a asp-controller="Dashboard" asp-action="Index" class="@(activeNav == "Monitoring" ? "active" : "")">
                    <i class="bi bi-graph-up"></i> Monitoring
                </a>
            </div>

            <div class="af-nav-section">Marketplace</div>
            <div class="af-nav-item">
                <a asp-controller="Marketplace" asp-action="Index" class="@(activeNav == "Marketplace" ? "active" : "")">
                    <i class="bi bi-shop"></i> Explorer
                </a>
            </div>
            <div class="af-nav-item">
                <a asp-controller="Agents" asp-action="Index" class="@(activeNav == "MyAgents" ? "active" : "")">
                    <i class="bi bi-collection"></i> Mes Agents
                </a>
            </div>
            <div class="af-nav-item">
                <a asp-controller="ComingSoon" asp-action="Index" asp-route-name="Achats" class="@(activeNav == "Purchases" ? "active" : "")">
                    <i class="bi bi-bag"></i> Achats
                </a>
            </div>

            <div class="af-nav-section">Facturation</div>
            <div class="af-nav-item">
                <a asp-controller="ComingSoon" asp-action="Index" asp-route-name="Abonnements">
                    <i class="bi bi-credit-card"></i> Abonnements
                </a>
            </div>
            <div class="af-nav-item">
                <a asp-controller="ComingSoon" asp-action="Index" asp-route-name="Facturation">
                    <i class="bi bi-receipt"></i> Facturation
                </a>
            </div>
            <div class="af-nav-item">
                <a asp-controller="ComingSoon" asp-action="Index" asp-route-name="Utilisation">
                    <i class="bi bi-bar-chart"></i> Utilisation
                </a>
            </div>

            <div class="af-nav-section">Paramètres</div>
            <div class="af-nav-item">
                <a asp-controller="ComingSoon" asp-action="Index" asp-route-name="Paramètres">
                    <i class="bi bi-gear"></i> Paramètres
                </a>
            </div>
            <div class="af-nav-item">
                <a asp-controller="ComingSoon" asp-action="Index" asp-route-name="Utilisateurs">
                    <i class="bi bi-people"></i> Utilisateurs
                </a>
            </div>
            <div class="af-nav-item">
                <a asp-controller="ComingSoon" asp-action="Index" asp-route-name="Rôles & Permissions">
                    <i class="bi bi-shield-lock"></i> Rôles &amp; Permissions
                </a>
            </div>
            <div class="af-nav-item">
                <a asp-controller="ComingSoon" asp-action="Index" asp-route-name="Audit Logs">
                    <i class="bi bi-journal-text"></i> Audit Logs
                </a>
            </div>
        </nav>

        <div class="af-sidebar-footer">
            <div class="af-sidebar-promo">
                <strong>Plan Pro</strong>
                Débloquez plus d'agents et de runs.
                <a asp-controller="Marketplace" asp-action="Index">Voir les plans</a>
            </div>
            <form asp-controller="Account" asp-action="Logout" method="post" class="mt-2">
                <button class="btn btn-sm w-100 text-start" style="color:#94a3b8;" type="submit">
                    <i class="bi bi-box-arrow-left me-2"></i> Déconnexion
                </button>
            </form>
        </div>
    </aside>

    <div class="af-main">
        <div class="af-topbar">
            <span class="af-topbar-title">@ViewData["Title"]</span>
            <div class="d-flex align-items-center gap-3">
                <span class="badge rounded-pill" style="background:#dcfce7;color:#16a34a;font-size:.75rem;">
                    <i class="bi bi-circle-fill me-1" style="font-size:.5rem;"></i> En ligne
                </span>
                <span class="text-muted small">@User.Identity?.Name</span>
            </div>
        </div>
        <div class="af-content">
            @RenderBody()
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
