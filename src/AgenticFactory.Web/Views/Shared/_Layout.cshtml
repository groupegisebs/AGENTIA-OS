<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Agentic Factory</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        :root {
            --af-primary: #6366f1;
            --af-primary-dark: #4f46e5;
            --af-sidebar-bg: #0f172a;
            --af-sidebar-text: #94a3b8;
            --af-sidebar-active: #6366f1;
        }
        * { font-family: 'Inter', sans-serif; }
        body { background: #f8fafc; min-height: 100vh; }

        /* Sidebar */
        .af-sidebar {
            width: 240px; min-height: 100vh; background: var(--af-sidebar-bg);
            position: fixed; top: 0; left: 0; z-index: 100;
            display: flex; flex-direction: column; padding: 0;
        }
        .af-sidebar-brand {
            padding: 20px 24px; border-bottom: 1px solid #1e293b;
            color: #fff; font-weight: 700; font-size: 1.1rem;
            display: flex; align-items: center; gap: 10px;
        }
        .af-sidebar-brand .brand-icon {
            width: 32px; height: 32px; background: var(--af-primary);
            border-radius: 8px; display: flex; align-items: center;
            justify-content: center; color: white; font-size: 0.9rem; font-weight: 700;
        }
        .af-nav { padding: 16px 0; flex: 1; }
        .af-nav-item a {
            display: flex; align-items: center; gap: 12px;
            padding: 10px 24px; color: var(--af-sidebar-text);
            text-decoration: none; font-size: 0.875rem; font-weight: 500;
            border-left: 3px solid transparent; transition: all 0.15s;
        }
        .af-nav-item a:hover, .af-nav-item a.active {
            color: #fff; background: rgba(99,102,241,.12);
            border-left-color: var(--af-primary);
        }
        .af-nav-section {
            padding: 16px 24px 6px; font-size: 0.7rem; font-weight: 600;
            color: #475569; text-transform: uppercase; letter-spacing: .08em;
        }
        .af-sidebar-footer {
            padding: 16px 24px; border-top: 1px solid #1e293b;
        }

        /* Main content */
        .af-main { margin-left: 240px; min-height: 100vh; }
        .af-topbar {
            background: #fff; border-bottom: 1px solid #e2e8f0;
            padding: 0 32px; height: 60px; display: flex;
            align-items: center; justify-content: space-between;
            position: sticky; top: 0; z-index: 50;
        }
        .af-topbar-title { font-weight: 600; font-size: 1rem; color: #0f172a; }
        .af-content { padding: 32px; }

        /* Cards */
        .af-card {
            background: #fff; border: 1px solid #e2e8f0; border-radius: 12px;
            padding: 24px; box-shadow: 0 1px 3px rgba(0,0,0,.05);
        }
        .af-stat-value { font-size: 2rem; font-weight: 700; color: #0f172a; }
        .af-stat-label { font-size: 0.8rem; color: #64748b; font-weight: 500; text-transform: uppercase; letter-spacing: .05em; }

        /* Auth pages */
        .af-auth-wrapper {
            min-height: 100vh; display: flex; align-items: center;
            justify-content: center; background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 100%);
        }
        .af-auth-card {
            background: #fff; border-radius: 16px; padding: 40px;
            width: 100%; max-width: 420px; box-shadow: 0 25px 50px rgba(0,0,0,.3);
        }
        .af-auth-logo {
            width: 48px; height: 48px; background: var(--af-primary);
            border-radius: 12px; display: flex; align-items: center;
            justify-content: center; color: white; font-size: 1.4rem; font-weight: 700;
            margin: 0 auto 24px;
        }
        .btn-af-primary {
            background: var(--af-primary); border: none; color: white;
            font-weight: 600; padding: 12px 24px; border-radius: 8px; width: 100%;
            transition: background .15s;
        }
        .btn-af-primary:hover { background: var(--af-primary-dark); color: white; }
        .form-control:focus { border-color: var(--af-primary); box-shadow: 0 0 0 3px rgba(99,102,241,.15); }
        .badge-status-active { background: #dcfce7; color: #16a34a; }
        .badge-status-error  { background: #fee2e2; color: #dc2626; }
        .badge-status-idle   { background: #f1f5f9; color: #64748b; }
    </style>
</head>
<body>
@{
    var isAuthPage = ViewContext.RouteData.Values["controller"]?.ToString() == "Account";
}

@if (!isAuthPage)
{
    <!-- Sidebar -->
    <aside class="af-sidebar">
        <div class="af-sidebar-brand">
            <div class="brand-icon">A</div>
            Agentic Factory
        </div>
        <nav class="af-nav">
            <div class="af-nav-section">Principal</div>
            <div class="af-nav-item">
                <a asp-controller="Dashboard" asp-action="Index">
                    <i class="bi bi-grid-1x2"></i> Dashboard
                </a>
            </div>
            <div class="af-nav-section">Plateforme</div>
            <div class="af-nav-item">
                <a href="#">
                    <i class="bi bi-robot"></i> Agents
                </a>
            </div>
            <div class="af-nav-item">
                <a href="#">
                    <i class="bi bi-lightning"></i> Déploiements
                </a>
            </div>
            <div class="af-nav-item">
                <a href="#">
                    <i class="bi bi-activity"></i> Exécutions
                </a>
            </div>
            <div class="af-nav-section">Marketplace</div>
            <div class="af-nav-item">
                <a href="#">
                    <i class="bi bi-shop"></i> Explorer
                </a>
            </div>
        </nav>
        <div class="af-sidebar-footer">
            <form asp-controller="Account" asp-action="Logout" method="post">
                <button class="btn btn-sm w-100 text-start" style="color:#94a3b8;" type="submit">
                    <i class="bi bi-box-arrow-left me-2"></i> Déconnexion
                </button>
            </form>
        </div>
    </aside>

    <!-- Main -->
    <div class="af-main">
        <div class="af-topbar">
            <span class="af-topbar-title">@ViewData["Title"]</span>
            <div class="d-flex align-items-center gap-3">
                <span class="badge rounded-pill" style="background:#dcfce7;color:#16a34a;font-size:.75rem;">
                    <i class="bi bi-circle-fill me-1" style="font-size:.5rem;"></i> En ligne
                </span>
                <span class="text-muted small">@User.Identity?.Name</span>
            </div>
        </div>
        <div class="af-content">
            @RenderBody()
        </div>
    </div>
}
else
{
    @RenderBody()
}

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
